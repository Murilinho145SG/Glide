// Pure chan throughput: 1 producer coro sends N times, main recvs N times.
// Isolates chan op cost from spawn overhead.

fn producer(c: chan<int>, n: int) {
    for i in 0..n {
        c.send(i);
    }
    c.close();
}

fn main() -> int {
    let n: int = 1000000;
    let c: chan<int> = make_chan(1024);
    spawn producer(c, n);
    let mut sum: int = 0;
    while let v = c.recv() {
        sum = sum + v;
    }
    println!("done sum=", sum);
    return 0;
}
