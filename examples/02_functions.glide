// Functions, parameters, return types.

fn add(a: int, b: int) -> int {
    return a + b;
}

fn doubled(n: int) -> int {
    return n * 2;
}

fn main() -> int {
    let x: int = add(3, 4);          // 7
    let y: int = doubled(x);         // 14
    println!("x =", x, " y =", y);
    return y;                        // exit code 14
}
