struct Point {
    x: int,
    y: int,
}

fn read(p: &Point) -> int {
    return p.x + p.y;
}

fn modify(p: &mut Point, dx: int) {
    p.x += dx;
}

fn main() -> int {
    let p: *Point = Point { x: 1, y: 2 };

    let s: int = read(&p);
    println!("sum =", s);

    modify(&mut p, 10);
    println!("after modify: p.x =", p.x);

    return 0;
}
