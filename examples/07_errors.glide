// Errors as values: `!T` is the result type, `?` propagates errors.
// `ok` and `err` are builtins specialized per fn return type.

fn parse_pos(n: int) -> !int {
    if n < 0 { return err("negative input"); }
    return ok(n * 2);
}

fn pipeline(n: int) -> !int {
    let v: int = parse_pos(n)?;  // if err, return err from pipeline
    return ok(v + 1);
}

fn main() -> int {
    let r: !int = pipeline(5);
    if r.ok { return r.val; }    // 11 on success
    return -1;
}
