// Anonymous functions (closures without capture). They lift to top-level
// fns and behave as function pointers — passable to other functions.

fn apply(f: fn(int) -> int, x: int) -> int {
    return f(x);
}

fn main() -> int {
    let inc = fn(n: int) -> int { return n + 1; };
    let sq  = fn(n: int) -> int { return n * n; };

    return apply(inc, 5) + apply(sq, 6);  // 6 + 36 = 42
}
