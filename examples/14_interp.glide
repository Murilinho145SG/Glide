// String interpolation: `${expr}` inside any string literal lowers to
// `format!(...)` so the placeholder is replaced by the value at runtime.

fn main() -> int {
    let name: string = "world";
    let n: int = 7;
    println!("hello, ${name}!");
    println!("${name} has ${n} items, doubled = ${n * 2}");
    let s: string = "answer = ${n + 35}";
    println!(s);
    return 0;
}
