// Borrows are non-owning views. They don't take ownership and can't be null.
// The borrow checker enforces aliasing rules without lifetime annotations.

fn read_only(p: &int) -> int {
    return *p + 1;               // read-through-borrow
}

fn write_into(p: &mut int) {
    *p = *p * 2;
}

fn main() -> int {
    let mut x: int = 21;
    write_into(&mut x);          // x is now 42
    return read_only(&x) - 1;    // returns 42
}
