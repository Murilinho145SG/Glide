extern fn srand(seed: uint);
extern fn rand() -> int;
extern fn time(t: *void) -> i64;

fn main() -> int {
    let now: i64 = time(null);
    srand(now as uint);

    let r1: int = rand();
    let r2: int = rand();

    println!("now =", now);
    println!("rand() =", r1);
    println!("rand() =", r2);

    let x: i64 = 9_000_000_000;
    let y: u64 = 18_000_000_000;
    println!("i64:", x);
    println!("u64:", y);

    return 0;
}
