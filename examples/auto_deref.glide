struct Point {
    x: int,
    y: int,
}

fn shift(p: *Point, dx: int, dy: int) {
    p.x += dx;
    p.y += dy;
}

fn distance_sq(p: *Point) -> int {
    return p.x * p.x + p.y * p.y;
}

fn main() -> int {
    let origin: Point = Point { x: 3, y: 4 };
    printf("before: (%d, %d)\n", origin.x, origin.y);

    shift(&origin, 10, 20);
    printf("after:  (%d, %d)\n", origin.x, origin.y);

    printf("dist^2: %d\n", distance_sq(&origin));
    return 0;
}
