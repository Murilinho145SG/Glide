{
  "name": "glide",
  "displayName": "Glide",
  "description": "Glide language support: syntax highlighting + LSP (diagnostics, hover, goto, completion, rename, refs).",
  "version": "0.1.0",
  "publisher": "glide-lang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:glide"
  ],
  "contributes": {
    "languages": [
      {
        "id": "glide",
        "aliases": ["Glide", "glide"],
        "extensions": [".glide"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "glide",
        "scopeName": "source.glide",
        "path": "./syntaxes/glide.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Glide",
      "properties": {
        "glide.path": {
          "type": "string",
          "default": "glide",
          "description": "Path to the `glide` executable. If left as `glide`, the extension looks on PATH."
        },
        "glide.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace LSP messages between VSCode and the Glide server."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p ."
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
