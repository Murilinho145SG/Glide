// T inference still works when the constraining use is inside a nested block.
fn main() -> int {
    let v = Vector::new();
    let mut total: int = 0;
    for let i: int = 0; i < 5; i++ {
        v.push(i * 10);
    }
    for let i: int = 0; i < 5; i++ {
        total = total + v.get(i);
    }
    return total;
}
