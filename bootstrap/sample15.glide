fn producer(c: chan<int>, n: int) {
    for let i: int = 1; i <= n; i++ {
        send(c, i);
    }
    close(c);
}

fn main() -> int {
    let c: chan<int> = make_chan(4);
    spawn producer(c, 5);
    let mut total: int = 0;
    let mut got: int = recv(c);
    while got != 0 {
        total = total + got;
        got = recv(c);
    }
    return total;
}
