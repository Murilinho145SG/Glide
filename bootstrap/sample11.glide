enum Shape {
    Circle(int),
    Rect(int, int),
    None,
}

fn area(s: Shape) -> int {
    let mut r: int = 0;
    match s {
        Shape::Circle(radius) => { r = radius * radius * 3; }
        Shape::Rect(w, h) => { r = w * h; }
        Shape::None => { r = 0; }
    }
    return r;
}

fn main() -> int {
    let c: Shape = Shape::Circle(5);
    let q: Shape = Shape::Rect(4, 7);
    return area(c) + area(q);
}
