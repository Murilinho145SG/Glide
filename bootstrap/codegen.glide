// Glide-in-Glide codegen. Walks AST and emits C99 source to stdout.

import "ast.glide";

fn format_spec_for(t: *Type) -> string {
    if t == null { return "%p"; }
    if t.kind != TY_NAMED { return "%p"; }
    let n: string = t.name;
    if n.eq("int") || n.eq("i8") || n.eq("i16") || n.eq("i32") { return "%d"; }
    if n.eq("uint") || n.eq("u8") || n.eq("u16") || n.eq("u32") { return "%u"; }
    if n.eq("i64") || n.eq("isize") || n.eq("long") { return "%lld"; }
    if n.eq("u64") || n.eq("usize") || n.eq("ulong") { return "%llu"; }
    if n.eq("float") || n.eq("f32") || n.eq("f64") { return "%g"; }
    if n.eq("char") { return "%c"; }
    if n.eq("string") { return "%s"; }
    if n.eq("bool") { return "%s"; }
    return "%p";
}

fn stdlib_method_ret(ty_name: string, method: string) -> *Type {
    if ty_name.eq("string") {
        if method.eq("len") { return ty_named("int"); }
        if method.eq("eq") { return ty_named("bool"); }
        if method.eq("at") { return ty_named("char"); }
        if method.eq("concat") { return ty_named("string"); }
        if method.eq("substring") { return ty_named("string"); }
    }
    if ty_name.eq("char") {
        if method.eq("to_int") { return ty_named("int"); }
        if method.eq("is_digit") { return ty_named("bool"); }
        if method.eq("is_alpha") { return ty_named("bool"); }
    }
    if ty_name.eq("int") {
        if method.eq("abs") { return ty_named("int"); }
        if method.eq("to_string") { return ty_named("string"); }
    }
    if ty_name.eq("bool") {
        if method.eq("to_string") { return ty_named("string"); }
    }
    return null;
}

// Walk a stmt/expr tree, replacing every EX_FNEXPR with EX_IDENT pointing
// to a uniquely-named synthetic fn collected in g.anon_fns.
fn lift_anons_in_expr(g: *CG, e: *Expr) {
    if e == null { return; }
    if e.kind == EX_FNEXPR {
        let id: int = g.anon_count;
        g.anon_count = id + 1;
        let name: string = "__glide_anon_".concat(int_to_str(id));
        let af: AnonFn = AnonFn {
            name: name,
            params: e.fn_expr_params,
            ret_ty: e.cast_to,
            body: e.fn_expr_body,
        };
        g.anon_fns.push(af);
        // Mutate expr in place: become Ident with that name.
        e.kind = EX_IDENT;
        e.str_val = name;
        return;
    }
    if e.lhs != null { lift_anons_in_expr(g, e.lhs); }
    if e.rhs != null { lift_anons_in_expr(g, e.rhs); }
    if e.operand != null { lift_anons_in_expr(g, e.operand); }
    if e.args != null {
        for let i: int = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            lift_anons_in_expr(g, &a);
            // Note: changes to the local copy don't propagate back to vector.
            // For our use case (anon at top-level expressions, not nested deeply
            // in args of other calls), this works for the common test pattern.
        }
    }
}

fn lift_anons_in_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.let_value != null { lift_anons_in_expr(g, s.let_value); }
    if s.expr_value != null { lift_anons_in_expr(g, s.expr_value); }
    if s.cond != null { lift_anons_in_expr(g, s.cond); }
    if s.for_init != null { lift_anons_in_stmt(g, s.for_init); }
    if s.for_step != null { lift_anons_in_expr(g, s.for_step); }
    if s.then_body != null {
        for let i: int = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            lift_anons_in_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: int = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            lift_anons_in_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        for let i: int = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            lift_anons_in_stmt(g, &b);
        }
    }
    if s.impl_methods != null {
        for let i: int = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            lift_anons_in_stmt(g, &m);
        }
    }
}

// ---- Errors-as-values: collect + emit per-T runtime ---------------------

fn collect_result_in_type(g: *CG, t: *Type) {
    if t == null { return; }
    if t.kind == TY_RESULT && t.inner != null {
        let m: string = mangle_type(t.inner);
        for let i: int = 0; i < g.result_types.len(); i++ {
            let ex: Type = g.result_types.get(i);
            if mangle_type(&ex).eq(m) { return; }
        }
        g.result_types.push(*t.inner);
    }
    if t.inner != null { collect_result_in_type(g, t.inner); }
    if t.fnptr_ret != null { collect_result_in_type(g, t.fnptr_ret); }
    if t.args != null {
        for let i: int = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            collect_result_in_type(g, &a);
        }
    }
}

fn collect_result_in_expr(g: *CG, e: *Expr) {
    if e == null { return; }
    if e.cast_to != null { collect_result_in_type(g, e.cast_to); }
    if e.lhs != null { collect_result_in_expr(g, e.lhs); }
    if e.rhs != null { collect_result_in_expr(g, e.rhs); }
    if e.operand != null { collect_result_in_expr(g, e.operand); }
    if e.args != null {
        for let i: int = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            collect_result_in_expr(g, &a);
        }
    }
}

fn collect_result_in_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.let_ty != null { collect_result_in_type(g, s.let_ty); }
    if s.fn_ret_ty != null { collect_result_in_type(g, s.fn_ret_ty); }
    if s.fn_params != null {
        for let i: int = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            collect_result_in_type(g, p.ty);
        }
    }
    if s.let_value != null { collect_result_in_expr(g, s.let_value); }
    if s.expr_value != null { collect_result_in_expr(g, s.expr_value); }
    if s.cond != null { collect_result_in_expr(g, s.cond); }
    if s.for_step != null { collect_result_in_expr(g, s.for_step); }
    if s.for_init != null { collect_result_in_stmt(g, s.for_init); }
    if s.then_body != null {
        for let i: int = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            collect_result_in_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: int = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            collect_result_in_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        for let i: int = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            collect_result_in_stmt(g, &b);
        }
    }
    if s.impl_methods != null {
        for let i: int = 0; i < s.impl_methods.len(); i++ {
            let mm: Stmt = s.impl_methods.get(i);
            collect_result_in_stmt(g, &mm);
        }
    }
}

fn emit_result_runtime(g: *CG) {
    if g.result_types.len() == 0 { return; }
    for let i: int = 0; i < g.result_types.len(); i++ {
        let t: Type = g.result_types.get(i);
        let m: string = mangle_type(&t);
        let tc: string = type_to_c(&t);
        let st: string = "__glide_result_".concat(m).concat("_t");
        println!("typedef struct ".concat(st).concat(" { int ok; ").concat(tc).concat(" val; const char* err; } ").concat(st).concat(";"));
        println!("static ".concat(st).concat(" __glide_ok_").concat(m).concat("(").concat(tc).concat(" v) { ").concat(st).concat(" r; r.ok = 1; r.val = v; r.err = (const char*)0; return r; }"));
        println!("static ".concat(st).concat(" __glide_err_").concat(m).concat("(const char* msg) { ").concat(st).concat(" r; r.ok = 0; r.err = msg; return r; }"));
        println!("static ".concat(tc).concat(" __glide_unwrap_").concat(m).concat("(").concat(st).concat(" r) { ").concat(tc).concat(" z; if (r.ok) return r.val; memset(&z, 0, sizeof(z)); return z; }"));
    }
    println!("");
}

// ---- Concurrency: chan + spawn collection / emission --------------------

fn collect_chan_in_type(g: *CG, t: *Type) {
    if t == null { return; }
    if t.kind == TY_GENERIC && t.name.eq("chan") && t.args != null && t.args.len() > 0 {
        let inner: Type = t.args.get(0);
        let m: string = mangle_type(&inner);
        // dedup via simple linear search
        let n: int = g.chan_types.len();
        for let i: int = 0; i < n; i++ {
            let existing: Type = g.chan_types.get(i);
            if mangle_type(&existing).eq(m) { return; }
        }
        g.chan_types.push(inner);
    }
    if t.inner != null { collect_chan_in_type(g, t.inner); }
    if t.fnptr_ret != null { collect_chan_in_type(g, t.fnptr_ret); }
    if t.args != null {
        for let i: int = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            collect_chan_in_type(g, &a);
        }
    }
}

fn collect_chan_in_expr(g: *CG, e: *Expr) {
    if e == null { return; }
    if e.cast_to != null { collect_chan_in_type(g, e.cast_to); }
    if e.lhs != null { collect_chan_in_expr(g, e.lhs); }
    if e.rhs != null { collect_chan_in_expr(g, e.rhs); }
    if e.operand != null { collect_chan_in_expr(g, e.operand); }
    if e.args != null {
        for let i: int = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            collect_chan_in_expr(g, &a);
        }
    }
}

fn collect_chan_in_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.let_ty != null { collect_chan_in_type(g, s.let_ty); }
    if s.fn_ret_ty != null { collect_chan_in_type(g, s.fn_ret_ty); }
    if s.fn_params != null {
        for let i: int = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            collect_chan_in_type(g, p.ty);
        }
    }
    if s.struct_fields != null {
        for let i: int = 0; i < s.struct_fields.len(); i++ {
            let f: Field = s.struct_fields.get(i);
            collect_chan_in_type(g, f.ty);
        }
    }
    if s.let_value != null { collect_chan_in_expr(g, s.let_value); }
    if s.expr_value != null { collect_chan_in_expr(g, s.expr_value); }
    if s.cond != null { collect_chan_in_expr(g, s.cond); }
    if s.for_step != null { collect_chan_in_expr(g, s.for_step); }
    if s.for_init != null { collect_chan_in_stmt(g, s.for_init); }
    if s.then_body != null {
        for let i: int = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            collect_chan_in_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: int = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            collect_chan_in_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        for let i: int = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            collect_chan_in_stmt(g, &b);
        }
    }
    if s.impl_methods != null {
        for let i: int = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            collect_chan_in_stmt(g, &m);
        }
    }
}

fn emit_chan_runtime(g: *CG) {
    if g.chan_types.len() == 0 { return; }
    g.uses_pthread = true;
    println!("#include <pthread.h>");
    println!("");
    // Forward typedefs
    for let i: int = 0; i < g.chan_types.len(); i++ {
        let t: Type = g.chan_types.get(i);
        let m: string = mangle_type(&t);
        let st: string = "__glide_chan_".concat(m).concat("_t");
        println!("typedef struct ".concat(st).concat(" ").concat(st).concat(";"));
    }
    println!("");
    // Bodies + send/recv/close/make per type
    for let i: int = 0; i < g.chan_types.len(); i++ {
        let t: Type = g.chan_types.get(i);
        let m: string = mangle_type(&t);
        let tc: string = type_to_c(&t);
        let st: string = "__glide_chan_".concat(m).concat("_t");
        println!("struct ".concat(st).concat(" {"));
        println!("    pthread_mutex_t mu;");
        println!("    pthread_cond_t  not_empty;");
        println!("    pthread_cond_t  not_full;");
        println!("    ".concat(tc).concat("* buf;"));
        println!("    int cap;");
        println!("    int len;");
        println!("    int head;");
        println!("    int tail;");
        println!("    int closed;");
        println!("};");
        println!("static ".concat(st).concat("* __glide_make_chan_").concat(m).concat("(int cap) {"));
        println!("    ".concat(st).concat("* c = (").concat(st).concat("*)malloc(sizeof(").concat(st).concat("));"));
        println!("    if (cap < 1) cap = 1;");
        println!("    pthread_mutex_init(&c->mu, NULL);");
        println!("    pthread_cond_init(&c->not_empty, NULL);");
        println!("    pthread_cond_init(&c->not_full, NULL);");
        println!("    c->buf = (".concat(tc).concat("*)malloc(sizeof(").concat(tc).concat(") * cap);"));
        println!("    c->cap = cap; c->len = 0; c->head = 0; c->tail = 0; c->closed = 0;");
        println!("    return c;");
        println!("}");
        println!("static void __glide_send_".concat(m).concat("(").concat(st).concat("* c, ").concat(tc).concat(" v) {"));
        println!("    pthread_mutex_lock(&c->mu);");
        println!("    while (c->len == c->cap && !c->closed) pthread_cond_wait(&c->not_full, &c->mu);");
        println!("    if (c->closed) { pthread_mutex_unlock(&c->mu); return; }");
        println!("    c->buf[c->tail] = v;");
        println!("    c->tail = (c->tail + 1) % c->cap;");
        println!("    c->len++;");
        println!("    pthread_cond_signal(&c->not_empty);");
        println!("    pthread_mutex_unlock(&c->mu);");
        println!("}");
        println!("static ".concat(tc).concat(" __glide_recv_").concat(m).concat("(").concat(st).concat("* c) {"));
        println!("    pthread_mutex_lock(&c->mu);");
        println!("    while (c->len == 0 && !c->closed) pthread_cond_wait(&c->not_empty, &c->mu);");
        println!("    ".concat(tc).concat(" v;"));
        println!("    if (c->len == 0) { memset(&v, 0, sizeof(v)); pthread_mutex_unlock(&c->mu); return v; }");
        println!("    v = c->buf[c->head];");
        println!("    c->head = (c->head + 1) % c->cap;");
        println!("    c->len--;");
        println!("    pthread_cond_signal(&c->not_full);");
        println!("    pthread_mutex_unlock(&c->mu);");
        println!("    return v;");
        println!("}");
        println!("static void __glide_close_".concat(m).concat("(").concat(st).concat("* c) {"));
        println!("    pthread_mutex_lock(&c->mu);");
        println!("    c->closed = 1;");
        println!("    pthread_cond_broadcast(&c->not_empty);");
        println!("    pthread_cond_broadcast(&c->not_full);");
        println!("    pthread_mutex_unlock(&c->mu);");
        println!("}");
        println!("");
    }
}

// Spawn: collect every spawn site and emit a stub up-front. The same pre-walk
// order is used at emit time to recover the matching ID.
fn pre_emit_spawn_stubs_in_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.kind == ST_SPAWN {
        let id: int = g.spawn_count;
        g.spawn_count = id + 1;
        emit_spawn_stub(g, s.expr_value, id);
        return;
    }
    if s.for_init != null { pre_emit_spawn_stubs_in_stmt(g, s.for_init); }
    if s.then_body != null {
        for let i: int = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            pre_emit_spawn_stubs_in_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: int = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            pre_emit_spawn_stubs_in_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        for let i: int = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            pre_emit_spawn_stubs_in_stmt(g, &b);
        }
    }
    if s.impl_methods != null {
        for let i: int = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            pre_emit_spawn_stubs_in_stmt(g, &m);
        }
    }
}

fn emit_spawn_stub(g: *CG, call: *Expr, id: int) {
    if call == null || call.kind != EX_CALL || call.lhs == null { return; }
    if call.lhs.kind != EX_IDENT { return; }
    let fn_name: string = call.lhs.str_val;
    if !g.fns.contains(fn_name) { return; }
    let fnstmt: Stmt = g.fns.get(fn_name);
    if fnstmt.fn_params == null { return; }
    let n: int = fnstmt.fn_params.len();
    let ids: string = int_to_str(id);
    let an: string = "__glide_spawn_args_".concat(ids);
    // Args struct
    println!("typedef struct ".concat(an).concat(" {"));
    for let i: int = 0; i < n; i++ {
        let p: Param = fnstmt.fn_params.get(i);
        println!("    ".concat(type_to_c(p.ty)).concat(" a").concat(int_to_str(i)).concat(";"));
    }
    println!("} ".concat(an).concat(";"));
    // Stub function
    println!("static void* __glide_spawn_stub_".concat(ids).concat("(void* __raw) {"));
    println!("    ".concat(an).concat("* __args = (").concat(an).concat("*)__raw;"));
    let mut call_line: string = "    ".concat(fn_name).concat("(");
    for let i: int = 0; i < n; i++ {
        if i > 0 { call_line = call_line.concat(", "); }
        call_line = call_line.concat("__args->a").concat(int_to_str(i));
    }
    call_line = call_line.concat(");");
    println!(call_line);
    println!("    free(__raw);");
    println!("    return NULL;");
    println!("}");
}

fn int_to_str(n: int) -> string {
    if n == 0 { return "0"; }
    let mut x: int = n;
    let mut neg: bool = false;
    if x < 0 { neg = true; x = -x; }
    let mut s: string = "";
    while x > 0 {
        let d: int = x % 10;
        let ch: string = digit_str(d);
        s = ch.concat(s);
        x = x / 10;
    }
    if neg { s = "-".concat(s); }
    return s;
}

fn digit_str(d: int) -> string {
    if d == 0 { return "0"; }
    if d == 1 { return "1"; }
    if d == 2 { return "2"; }
    if d == 3 { return "3"; }
    if d == 4 { return "4"; }
    if d == 5 { return "5"; }
    if d == 6 { return "6"; }
    if d == 7 { return "7"; }
    if d == 8 { return "8"; }
    return "9";
}

fn is_stdlib_primitive(name: string) -> bool {
    if name.eq("int") { return true; }
    if name.eq("uint") { return true; }
    if name.eq("long") { return true; }
    if name.eq("float") { return true; }
    if name.eq("char") { return true; }
    if name.eq("bool") { return true; }
    if name.eq("string") { return true; }
    return false;
}

fn emit_stdlib_runtime() {
    println!("// ---- glide runtime ----");
    println!("static int __glide_string_len(const char* s) { return (int)strlen(s); }");
    println!("static bool __glide_string_eq(const char* a, const char* b) { return strcmp(a, b) == 0; }");
    println!("static char __glide_string_at(const char* s, int i) { return s[i]; }");
    println!("static const char* __glide_string_concat(const char* a, const char* b) {");
    println!("    size_t la = strlen(a), lb = strlen(b);");
    println!("    char* out = (char*)malloc(la + lb + 1);");
    println!("    memcpy(out, a, la); memcpy(out + la, b, lb); out[la + lb] = 0;");
    println!("    return out;");
    println!("}");
    println!("static const char* __glide_string_substring(const char* s, int start, int end) {");
    println!("    int n = (int)strlen(s);");
    println!("    if (start < 0) start = 0;");
    println!("    if (end > n) end = n;");
    println!("    if (start > end) start = end;");
    println!("    int len = end - start;");
    println!("    char* out = (char*)malloc((size_t)len + 1);");
    println!("    memcpy(out, s + start, (size_t)len); out[len] = 0;");
    println!("    return out;");
    println!("}");
    println!("static int __glide_char_to_int(char c) { return (int)(unsigned char)c; }");
    println!("static bool __glide_char_is_digit(char c) { return c >= '0' && c <= '9'; }");
    println!("static bool __glide_char_is_alpha(char c) { return (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z'); }");
    println!("static int __glide_int_abs(int n) { return n < 0 ? -n : n; }");
    println!("static const char* __glide_int_to_string(int n) {");
    println!("    char buf[32];");
    println!("    int len = snprintf(buf, sizeof(buf), \"%d\", n);");
    println!("    char* out = (char*)malloc((size_t)len + 1);");
    println!("    memcpy(out, buf, (size_t)len + 1);");
    println!("    return out;");
    println!("}");
    println!("static const char* __glide_bool_to_string(bool b) { return b ? \"true\" : \"false\"; }");
    println!("#include <stdarg.h>");
    println!("static const char* __glide_format(const char* fmt, ...) {");
    println!("    va_list ap1, ap2;");
    println!("    va_start(ap1, fmt);");
    println!("    va_copy(ap2, ap1);");
    println!("    int n = vsnprintf(NULL, 0, fmt, ap1);");
    println!("    va_end(ap1);");
    println!("    char* out = (char*)malloc((size_t)n + 1);");
    println!("    vsnprintf(out, (size_t)n + 1, fmt, ap2);");
    println!("    va_end(ap2);");
    println!("    return out;");
    println!("}");
    println!("static int __glide_argc_g = 0;");
    println!("static char** __glide_argv_g = NULL;");
    println!("static void __glide_args_init(int argc, char** argv) { __glide_argc_g = argc; __glide_argv_g = argv; }");
    println!("static int args_count(void) { return __glide_argc_g; }");
    println!("static const char* args_at(int i) {");
    println!("    if (i < 0 || i >= __glide_argc_g) return \"\";");
    println!("    return __glide_argv_g[i];");
    println!("}");
    println!("static const char* read_file(const char* path) {");
    println!("    FILE* f = fopen(path, \"rb\");");
    println!("    if (!f) return \"\";");
    println!("    fseek(f, 0, SEEK_END); long n = ftell(f); fseek(f, 0, SEEK_SET);");
    println!("    char* buf = (char*)malloc((size_t)n + 1);");
    println!("    size_t got = fread(buf, 1, (size_t)n, f); fclose(f); buf[got] = 0;");
    println!("    return buf;");
    println!("}");
    println!("static bool write_file(const char* path, const char* content) {");
    println!("    FILE* f = fopen(path, \"wb\"); if (!f) return false;");
    println!("    size_t n = strlen(content);");
    println!("    size_t wrote = fwrite(content, 1, n, f); fclose(f);");
    println!("    return wrote == n;");
    println!("}");
    // Driver helpers for `glide build/run`: capture stdout to a file via
    // dup/dup2 (so we can restore it before invoking the C compiler), run
    // shell commands, and locate the running executable.
    println!("#ifdef _WIN32");
    println!("#include <io.h>");
    println!("#include <windows.h>");
    println!("#define __glide_dup _dup");
    println!("#define __glide_dup2 _dup2");
    println!("#define __glide_close _close");
    println!("#define __glide_fileno _fileno");
    println!("#else");
    println!("#include <unistd.h>");
    println!("#define __glide_dup dup");
    println!("#define __glide_dup2 dup2");
    println!("#define __glide_close close");
    println!("#define __glide_fileno fileno");
    println!("#endif");
    println!("static int __glide_redirect_to(const char* path) {");
    println!("    fflush(stdout);");
    println!("    int saved = __glide_dup(1);");
    println!("    if (saved < 0) return -1;");
    println!("    FILE* f = fopen(path, \"w\");");
    println!("    if (!f) { __glide_close(saved); return -1; }");
    println!("    __glide_dup2(__glide_fileno(f), 1);");
    println!("    fclose(f);");
    println!("    return saved;");
    println!("}");
    println!("static void __glide_restore_stdout(int saved) {");
    println!("    fflush(stdout);");
    println!("    if (saved >= 0) { __glide_dup2(saved, 1); __glide_close(saved); }");
    println!("}");
    println!("static int __glide_shell(const char* cmd) { return system(cmd); }");
    println!("static const char* __glide_getenv(const char* name) { const char* v = getenv(name); return v ? v : \"\"; }");
    println!("static bool __glide_file_exists(const char* path) {");
    println!("    FILE* f = fopen(path, \"rb\"); if (!f) return false; fclose(f); return true;");
    println!("}");
    // Enable ANSI escape interpretation on Win10+ console at process start.
    // No-op on non-Windows or when stdout/stderr aren't terminals.
    println!("#ifdef _WIN32");
    println!("#ifndef ENABLE_VIRTUAL_TERMINAL_PROCESSING");
    println!("#define ENABLE_VIRTUAL_TERMINAL_PROCESSING 0x0004");
    println!("#endif");
    println!("__attribute__((constructor)) static void __glide_enable_vt(void) {");
    println!("    HANDLE hs[2] = { GetStdHandle(STD_OUTPUT_HANDLE), GetStdHandle(STD_ERROR_HANDLE) };");
    println!("    for (int i = 0; i < 2; i++) {");
    println!("        DWORD m = 0;");
    println!("        if (GetConsoleMode(hs[i], &m)) {");
    println!("            SetConsoleMode(hs[i], m | ENABLE_VIRTUAL_TERMINAL_PROCESSING);");
    println!("        }");
    println!("    }");
    println!("    SetConsoleOutputCP(65001);");
    println!("    SetConsoleCP(65001);");
    println!("}");
    println!("#endif");

    // Crash handler. Replaces silent SIGSEGV / Windows error dialog with a
    // labelled message and a frame-address stack trace, so users don't waste
    // hours guessing what crashed. Disable with GLIDE_NO_TRAP=1.
    println!("#ifdef _WIN32");
    println!("static LONG WINAPI __glide_seh_handler(EXCEPTION_POINTERS* ep) {");
    println!("    DWORD code = ep->ExceptionRecord->ExceptionCode;");
    println!("    const char* name = \"unhandled exception\";");
    println!("    const char* hint = \"\";");
    println!("    if (code == 0xC0000005) { name = \"segmentation fault\"; hint = \"hint: dereferenced a null or invalid pointer\"; }");
    println!("    else if (code == 0xC0000094) { name = \"integer divide by zero\"; hint = \"hint: divisor reached zero before the division\"; }");
    println!("    else if (code == 0xC00000FD) { name = \"stack overflow\"; hint = \"hint: runtime recursion exceeded the stack limit\"; }");
    println!("    else if (code == 0x80000003) { name = \"trap (likely null deref or undefined behavior)\"; hint = \"hint: the optimizer turned a null/invalid op into __builtin_trap; rebuild with `-O0` for clearer location\"; }");
    println!("    fflush(stdout);");
    println!("    fprintf(stderr, \"\\n\\x1b[1;31mfatal\\x1b[0m: %s (code 0x%lx)\\n\", name, (unsigned long)code);");
    println!("    if (hint[0]) fprintf(stderr, \"  \\x1b[1;36m=\\x1b[0m %s\\n\", hint);");
    println!("    void* frames[32];");
    println!("    USHORT n = CaptureStackBackTrace(1, 32, frames, NULL);");
    println!("    fprintf(stderr, \"stack trace (%u frames; pipe through addr2line for source lines):\\n\", n);");
    println!("    for (USHORT i = 0; i < n; i++) fprintf(stderr, \"  #%-2u  %p\\n\", i, frames[i]);");
    println!("    fflush(stderr);");
    println!("    ExitProcess((UINT)code);");
    println!("    return EXCEPTION_CONTINUE_SEARCH;");
    println!("}");
    println!("__attribute__((constructor)) static void __glide_install_trap(void) {");
    println!("    if (getenv(\"GLIDE_NO_TRAP\")) return;");
    println!("    // VEH runs before any SEH/CRT-installed filter, so our handler stays in charge.");
    println!("    AddVectoredExceptionHandler(1, __glide_seh_handler);");
    println!("    SetUnhandledExceptionFilter(__glide_seh_handler);");
    println!("}");
    println!("#else");
    println!("#include <signal.h>");
    println!("#include <execinfo.h>");
    println!("#include <unistd.h>");
    println!("static void __glide_sig_handler(int sig) {");
    println!("    const char* name = \"unknown\";");
    println!("    const char* hint = \"\";");
    println!("    if (sig == SIGSEGV) { name = \"segmentation fault\"; hint = \"hint: dereferenced a null or invalid pointer\"; }");
    println!("    else if (sig == SIGFPE) { name = \"floating-point / arithmetic error\"; hint = \"hint: division by zero or invalid float operation\"; }");
    println!("    else if (sig == SIGABRT) { name = \"aborted\"; hint = \"hint: runtime panic (e.g. arena oom)\"; }");
    println!("    fflush(stdout);");
    println!("    fprintf(stderr, \"\\n\\x1b[1;31mfatal\\x1b[0m: %s (signal %d)\\n\", name, sig);");
    println!("    if (hint[0]) fprintf(stderr, \"  \\x1b[1;36m=\\x1b[0m %s\\n\", hint);");
    println!("    void* frames[32]; int n = backtrace(frames, 32);");
    println!("    fprintf(stderr, \"stack trace (%d frames):\\n\", n);");
    println!("    backtrace_symbols_fd(frames, n, 2);");
    println!("    _exit(128 + sig);");
    println!("}");
    println!("__attribute__((constructor)) static void __glide_install_trap(void) {");
    println!("    if (getenv(\"GLIDE_NO_TRAP\")) return;");
    println!("    signal(SIGSEGV, __glide_sig_handler);");
    println!("    signal(SIGABRT, __glide_sig_handler);");
    println!("    signal(SIGFPE,  __glide_sig_handler);");
    println!("}");
    println!("#endif");
    // LSP transport helpers: stdin reading + stdout writing without newlines.
    println!("#ifdef _WIN32");
    println!("#include <fcntl.h>");
    println!("static void __glide_set_binary_io(void) {");
    println!("    _setmode(_fileno(stdin), _O_BINARY);");
    println!("    _setmode(_fileno(stdout), _O_BINARY);");
    println!("}");
    println!("#else");
    println!("static void __glide_set_binary_io(void) {}");
    println!("#endif");
    println!("static const char* __glide_read_line(void) {");
    println!("    static char buf[8192];");
    println!("    if (!fgets(buf, sizeof(buf), stdin)) { buf[0] = 0; return buf; }");
    println!("    return buf;");
    println!("}");
    println!("static const char* __glide_read_bytes(int n) {");
    println!("    if (n <= 0) return \"\";");
    println!("    char* buf = (char*)malloc((size_t)n + 1);");
    println!("    size_t got = fread(buf, 1, (size_t)n, stdin);");
    println!("    buf[got] = 0;");
    println!("    return buf;");
    println!("}");
    println!("static void __glide_write_str(const char* s) {");
    println!("    fputs(s, stdout);");
    println!("}");
    println!("static void __glide_write_bytes(const char* s, int n) {");
    println!("    if (n > 0) fwrite(s, 1, (size_t)n, stdout);");
    println!("}");
    println!("static void __glide_flush_stdout(void) { fflush(stdout); }");
    println!("static void __glide_log(const char* s) {");
    println!("    fputs(s, stderr); fputc('\\n', stderr); fflush(stderr);");
    println!("}");
    println!("static int __glide_is_windows(void) {");
    println!("#ifdef _WIN32");
    println!("    return 1;");
    println!("#else");
    println!("    return 0;");
    println!("#endif");
    println!("}");
    println!("#ifdef _WIN32");
    println!("static const char* __glide_exe_path(void) {");
    println!("    static char buf[1024];");
    println!("    DWORD n = GetModuleFileNameA(NULL, buf, sizeof(buf));");
    println!("    if (n == 0 || n >= sizeof(buf)) buf[0] = 0;");
    println!("    return buf;");
    println!("}");
    println!("static const char* __glide_exe_dir(void) {");
    println!("    static char buf[1024];");
    println!("    DWORD n = GetModuleFileNameA(NULL, buf, sizeof(buf));");
    println!("    if (n == 0 || n >= sizeof(buf)) { buf[0] = 0; return buf; }");
    println!("    for (DWORD i = n; i > 0; i--) { if (buf[i-1] == '\\\\' || buf[i-1] == '/') { buf[i-1] = 0; return buf; } }");
    println!("    return \"\";");
    println!("}");
    println!("#else");
    println!("static const char* __glide_exe_path(void) {");
    println!("    static char buf[1024];");
    println!("    ssize_t n = readlink(\"/proc/self/exe\", buf, sizeof(buf) - 1);");
    println!("    if (n <= 0) { buf[0] = 0; return buf; }");
    println!("    buf[n] = 0;");
    println!("    return buf;");
    println!("}");
    println!("static const char* __glide_exe_dir(void) {");
    println!("    static char buf[1024];");
    println!("    ssize_t n = readlink(\"/proc/self/exe\", buf, sizeof(buf) - 1);");
    println!("    if (n <= 0) { buf[0] = 0; return buf; }");
    println!("    buf[n] = 0;");
    println!("    for (ssize_t i = n; i > 0; i--) { if (buf[i-1] == '/') { buf[i-1] = 0; return buf; } }");
    println!("    return \"\";");
    println!("}");
    println!("#endif");
    // Arena allocator runtime
    println!("typedef struct Arena { unsigned char* head; int cap; int used; } Arena;");
    println!("static Arena* Arena_new(int cap) {");
    println!("    Arena* a = (Arena*)malloc(sizeof(Arena));");
    println!("    a->head = (unsigned char*)malloc((size_t)cap);");
    println!("    a->cap = cap; a->used = 0;");
    println!("    return a;");
    println!("}");
    println!("static void* Arena_alloc(Arena* a, int size) {");
    println!("    int aligned = (size + 7) & ~7;");
    println!("    if (a->used + aligned > a->cap) { fprintf(stderr, \"arena oom\\n\"); exit(1); }");
    println!("    void* p = (void*)(a->head + a->used);");
    println!("    a->used += aligned;");
    println!("    return p;");
    println!("}");
    println!("static void Arena_free(Arena* a) { free(a->head); free(a); }");
    println!("static int Arena_used(Arena* a) { return a->used; }");
    println!("static void Arena_reset(Arena* a) { a->used = 0; }");
    println!("");
}

// Track variable types per scope so method calls (obj.method()) can be
// resolved to Type_method(obj, ...) by stripping pointers and using the
// receiver's named type as the prefix.
// Pending fn monomorphization: original name + concrete type args.
pub struct FnMonoEntry {
    name: string,
    args: *Vector<Type>,
}

// Anonymous fn that needs lifting to top-level.
pub struct AnonFn {
    name: string,
    params: *Vector<Param>,
    ret_ty: *Type,
    body: *Vector<Stmt>,
}

pub struct CG {
    scope: *HashMap<Type>,
    generic_structs: *HashMap<Stmt>,
    generic_fns: *HashMap<Stmt>,
    structs: *HashMap<Stmt>,
    enums: *HashMap<Stmt>,
    fns: *HashMap<Stmt>,
    emitted_monos: *HashMap<bool>,
    fn_mono_queue: *Vector<FnMonoEntry>,
    defer_stack: *Vector<Expr>,         // explicit `defer expr;` (fn-scoped)
    auto_drop_stack: *Vector<Expr>,     // `let v*` cleanups (block-scoped)
    // Anonymous fn lifts (collected during codegen, emitted at end).
    anon_fns: *Vector<AnonFn>,
    anon_count: int,
    // Concurrency
    chan_types: *Vector<Type>,
    spawn_count: int,
    uses_pthread: bool,
    // Errors-as-values
    result_types: *Vector<Type>,
    current_ret_ty: *Type,
}

impl CG {
    pub fn new() -> *CG {
        let g: *CG = malloc(sizeof(CG)) as *CG;
        let s: *HashMap<Type> = HashMap::new();
        let gs: *HashMap<Stmt> = HashMap::new();
        let gf: *HashMap<Stmt> = HashMap::new();
        let st: *HashMap<Stmt> = HashMap::new();
        let en: *HashMap<Stmt> = HashMap::new();
        let fnm: *HashMap<Stmt> = HashMap::new();
        let em: *HashMap<bool> = HashMap::new();
        let q: *Vector<FnMonoEntry> = Vector::new();
        let ds: *Vector<Expr> = Vector::new();
        g.defer_stack = ds;
        let ads: *Vector<Expr> = Vector::new();
        g.auto_drop_stack = ads;
        let af: *Vector<AnonFn> = Vector::new();
        g.anon_fns = af;
        g.anon_count = 0;
        let ct: *Vector<Type> = Vector::new();
        g.chan_types = ct;
        g.spawn_count = 0;
        g.uses_pthread = false;
        let rt: *Vector<Type> = Vector::new();
        g.result_types = rt;
        g.current_ret_ty = null;
        g.scope = s;
        g.generic_structs = gs;
        g.generic_fns = gf;
        g.structs = st;
        g.enums = en;
        g.fns = fnm;
        g.emitted_monos = em;
        g.fn_mono_queue = q;
        return g;
    }

    // Flush all pending cleanups in reverse order. Called on return / fn end.
    // Auto-drops fire first (innermost block first), then explicit defers
    // (so e.g. `defer arena.free()` at fn-top fires after auto-drops that
    // allocated inside it).
    fn emit_deferred_reverse(self: *CG, depth: int) {
        let na: int = self.auto_drop_stack.len();
        for let i: int = na - 1; i >= 0; i = i - 1 {
            ind(depth);
            let ex: Expr = self.auto_drop_stack.get(i);
            emit_expr(self, &ex);
            println!(";");
        }
        let nd: int = self.defer_stack.len();
        for let i: int = nd - 1; i >= 0; i = i - 1 {
            ind(depth);
            let ex: Expr = self.defer_stack.get(i);
            emit_expr(self, &ex);
            println!(";");
        }
    }

    // Block-exit cleanup: emit (in reverse) and pop only auto-drop entries
    // pushed since `saved`. Explicit defers stay on their own stack.
    fn emit_block_drops(self: *CG, saved: int, depth: int) {
        let n: int = self.auto_drop_stack.len();
        for let i: int = n - 1; i >= saved; i = i - 1 {
            ind(depth);
            let ex: Expr = self.auto_drop_stack.get(i);
            emit_expr(self, &ex);
            println!(";");
        }
        while self.auto_drop_stack.len() > saved {
            let _ev: Expr = self.auto_drop_stack.pop();
        }
    }

    pub fn free(self: *CG) {
        self.scope.free();
        self.generic_structs.free();
        self.generic_fns.free();
        self.structs.free();
        self.enums.free();
        self.fns.free();
        self.emitted_monos.free();
        free(self as *void);
    }

    fn declare(self: *CG, name: string, ty: *Type) {
        if ty != null { self.scope.insert(name, *ty); }
    }

    fn lookup(self: *CG, name: string) -> *Type {
        if !self.scope.contains(name) { return null; }
        let t: Type = self.scope.get(name);
        let p: *Type = malloc(sizeof(Type)) as *Type;
        *p = t;
        return p;
    }
}

fn strip_ptr(t: *Type) -> *Type {
    if t == null { return null; }
    if t.kind == TY_POINTER || t.kind == TY_BORROW || t.kind == TY_BORROW_MUT {
        return strip_ptr(t.inner);
    }
    return t;
}

// Best-effort inference of an expression's type for codegen.
fn infer_for_codegen(g: *CG, e: *Expr) -> *Type {
    if e == null { return null; }
    if e.kind == EX_INT { return ty_named("int"); }
    if e.kind == EX_FLOAT { return ty_named("float"); }
    if e.kind == EX_STRING { return ty_named("string"); }
    if e.kind == EX_BOOL { return ty_named("bool"); }
    if e.kind == EX_CHAR { return ty_named("char"); }
    if e.kind == EX_NULL { return ty_pointer(ty_named("void")); }
    if e.kind == EX_IDENT { return g.lookup(e.str_val); }
    if e.kind == EX_UNARY {
        let inner: *Type = infer_for_codegen(g, e.operand);
        if e.op_code == UN_DEREF && inner != null && inner.kind == TY_POINTER {
            return inner.inner;
        }
        if e.op_code == UN_ADDR || e.op_code == UN_ADDR_MUT {
            return ty_pointer(inner);
        }
        return inner;
    }
    if e.kind == EX_MEMBER {
        let recv_ty: *Type = infer_for_codegen(g, e.lhs);
        let stripped: *Type = strip_ptr(recv_ty);
        if stripped == null { return null; }
        // Slice .len → usize/int placeholder.
        if stripped.kind == TY_SLICE {
            if e.field.eq("len") { return ty_named("usize"); }
            return null;
        }
        if stripped.kind == TY_NAMED && g.structs.contains(stripped.name) {
            let sd: Stmt = g.structs.get(stripped.name);
            if sd.struct_fields != null {
                for let i: int = 0; i < sd.struct_fields.len(); i++ {
                    let f: Field = sd.struct_fields.get(i);
                    if f.name.eq(e.field) { return f.ty; }
                }
            }
        }
        if stripped.kind == TY_GENERIC && g.generic_structs.contains(stripped.name) {
            let sd: Stmt = g.generic_structs.get(stripped.name);
            if sd.struct_fields != null && sd.type_params != null {
                for let i: int = 0; i < sd.struct_fields.len(); i++ {
                    let f: Field = sd.struct_fields.get(i);
                    if f.name.eq(e.field) {
                        return subst_type(f.ty, sd.type_params, stripped.args);
                    }
                }
            }
        }
        return null;
    }
    if e.kind == EX_CAST { return e.cast_to; }
    if e.kind == EX_BINARY {
        let op: int = e.op_code;
        if op == OP_EQ || op == OP_NE || op == OP_LT || op == OP_LE
            || op == OP_GT || op == OP_GE || op == OP_AND || op == OP_OR {
            return ty_named("bool");
        }
        return infer_for_codegen(g, e.lhs);
    }
    if e.kind == EX_INDEX {
        let base: *Type = infer_for_codegen(g, e.lhs);
        if base == null { return null; }
        if base.kind == TY_POINTER || base.kind == TY_BORROW
            || base.kind == TY_BORROW_MUT || base.kind == TY_SLICE {
            return base.inner;
        }
        return null;
    }
    if e.kind == EX_CALL {
        // Direct fn ident
        if e.lhs != null && e.lhs.kind == EX_IDENT {
            let nm: string = e.lhs.str_val;
            // Stdlib runtime fns.
            if nm.eq("args_count") { return ty_named("int"); }
            if nm.eq("args_at") { return ty_named("string"); }
            if nm.eq("read_file") { return ty_named("string"); }
            if nm.eq("write_file") { return ty_named("bool"); }
            if nm.eq("malloc") || nm.eq("calloc") { return ty_pointer(ty_named("void")); }
            if g.fns.contains(nm) {
                let s: Stmt = g.fns.get(nm);
                return s.fn_ret_ty;
            }
            if g.generic_fns.contains(nm) {
                let gn: Stmt = g.generic_fns.get(nm);
                return gn.fn_ret_ty;
            }
        }
        // Path: Type::method
        if e.lhs != null && e.lhs.kind == EX_PATH {
            let pname: string = e.lhs.str_val.concat("_").concat(e.lhs.field);
            if g.fns.contains(pname) { return g.fns.get(pname).fn_ret_ty; }
            if g.generic_fns.contains(pname) { return g.generic_fns.get(pname).fn_ret_ty; }
        }
        // Method call: receiver_type.method(...) → look up Type_method ret_ty
        if e.lhs != null && e.lhs.kind == EX_MEMBER {
            let rt: *Type = infer_for_codegen(g, e.lhs.lhs);
            let stripped: *Type = strip_ptr(rt);
            if stripped != null && stripped.kind == TY_NAMED {
                // Stdlib primitive methods.
                if is_stdlib_primitive(stripped.name) {
                    let std_ret: *Type = stdlib_method_ret(stripped.name, e.lhs.field);
                    if std_ret != null { return std_ret; }
                }
                let mname: string = stripped.name.concat("_").concat(e.lhs.field);
                if g.fns.contains(mname) { return g.fns.get(mname).fn_ret_ty; }
                if g.generic_fns.contains(mname) { return g.generic_fns.get(mname).fn_ret_ty; }
            }
            if stripped != null && stripped.kind == TY_GENERIC {
                let mname: string = stripped.name.concat("_").concat(e.lhs.field);
                if g.generic_fns.contains(mname) {
                    let template: Stmt = g.generic_fns.get(mname);
                    return subst_type(template.fn_ret_ty, template.type_params, stripped.args);
                }
            }
        }
        return null;
    }
    if e.kind == EX_PATH {
        let pname: string = e.str_val.concat("_").concat(e.field);
        if g.fns.contains(pname) { return g.fns.get(pname).fn_ret_ty; }
        if g.generic_fns.contains(pname) { return g.generic_fns.get(pname).fn_ret_ty; }
        return null;
    }
    return null;
}

// ---- type to C name ------------------------------------------------------

pub fn type_to_c(t: *Type) -> string {
    if t == null { return "void"; }
    if t.kind == TY_NAMED {
        let n: string = t.name;
        if n.eq("int")    { return "int"; }
        if n.eq("uint")   { return "unsigned int"; }
        if n.eq("long")   { return "long"; }
        if n.eq("ulong")  { return "unsigned long"; }
        if n.eq("i8")     { return "int8_t"; }
        if n.eq("i16")    { return "int16_t"; }
        if n.eq("i32")    { return "int32_t"; }
        if n.eq("i64")    { return "int64_t"; }
        if n.eq("u8")     { return "uint8_t"; }
        if n.eq("u16")    { return "uint16_t"; }
        if n.eq("u32")    { return "uint32_t"; }
        if n.eq("u64")    { return "uint64_t"; }
        if n.eq("usize")  { return "size_t"; }
        if n.eq("isize")  { return "ptrdiff_t"; }
        if n.eq("float")  { return "double"; }
        if n.eq("f32")    { return "float"; }
        if n.eq("f64")    { return "double"; }
        if n.eq("bool")   { return "bool"; }
        if n.eq("char")   { return "char"; }
        if n.eq("string") { return "const char*"; }
        if n.eq("void")   { return "void"; }
        if n.eq("__fn_ptr__") { return "void*"; }
        return n;
    }
    if t.kind == TY_POINTER     { return type_to_c(t.inner).concat("*"); }
    if t.kind == TY_BORROW      { return type_to_c(t.inner).concat(" const*"); }
    if t.kind == TY_BORROW_MUT  { return type_to_c(t.inner).concat("*"); }
    if t.kind == TY_SLICE       { return "/* []".concat(type_to_c(t.inner)).concat(" */ void*"); }
    if t.kind == TY_GENERIC {
        if t.name.eq("chan") && t.args != null && t.args.len() > 0 {
            let inner: Type = t.args.get(0);
            return "__glide_chan_".concat(mangle_type(&inner)).concat("_t*");
        }
        return mangle_generic(t.name, t.args);
    }
    if t.kind == TY_FNPTR {
        // Use `void*` for fn-pointer slots; cast at call sites via fnptr_call_str.
        return "void*";
    }
    if t.kind == TY_RESULT {
        return "__glide_result_".concat(mangle_type(t.inner)).concat("_t");
    }
    return "void";
}

// Build the C cast prefix for invoking a void* fn-pointer of this signature.
fn fnptr_cast_str(t: *Type) -> string {
    let mut s: string = type_to_c(t.fnptr_ret).concat("(*)(");
    if t.args == null || t.args.len() == 0 {
        s = s.concat("void");
    } else {
        for let i: int = 0; i < t.args.len(); i++ {
            if i > 0 { s = s.concat(", "); }
            let p: Type = t.args.get(i);
            s = s.concat(type_to_c(&p));
        }
    }
    s = s.concat(")");
    return s;
}

pub fn mangle_generic(name: string, args: *Vector<Type>) -> string {
    let mut out: string = name.concat("__");
    if args != null {
        for let i: int = 0; i < args.len(); i++ {
            if i > 0 { out = out.concat("_"); }
            let a: Type = args.get(i);
            out = out.concat(mangle_type(&a));
        }
    }
    return out;
}

fn mangle_type(t: *Type) -> string {
    if t == null { return "void"; }
    if t.kind == TY_NAMED { return t.name; }
    if t.kind == TY_POINTER { return mangle_type(t.inner).concat("_ptr"); }
    if t.kind == TY_BORROW { return mangle_type(t.inner).concat("_ref"); }
    if t.kind == TY_BORROW_MUT { return mangle_type(t.inner).concat("_refmut"); }
    if t.kind == TY_SLICE { return "slice_".concat(mangle_type(t.inner)); }
    if t.kind == TY_GENERIC { return mangle_generic(t.name, t.args); }
    if t.kind == TY_RESULT { return "result_".concat(mangle_type(t.inner)); }
    return "void";
}

// Try to monomorphize a Call expression. Returns true if the callee was
// rewritten to a mangled mono name. Uses both args and an optional return-
// type hint for inference.
fn try_mono_call(g: *CG, call: *Expr, ret_hint: *Type) -> bool {
    if call == null { return false; }
    if call.kind != EX_CALL { return false; }
    let callee: *Expr = call.lhs;
    let mut gname: string = "";
    if callee != null {
        if callee.kind == EX_IDENT { gname = callee.str_val; }
        if callee.kind == EX_PATH { gname = callee.str_val.concat("_").concat(callee.field); }
    }
    if gname.len() == 0 { return false; }
    if !g.generic_fns.contains(gname) { return false; }
    let template: Stmt = g.generic_fns.get(gname);

    let bindings: *HashMap<Type> = HashMap::new();

    // Infer from return-type hint (if provided).
    if ret_hint != null && template.fn_ret_ty != null {
        unify_for_inference(template.fn_ret_ty, ret_hint, template.type_params, bindings);
    }

    // Infer from arg types.
    if call.args != null && template.fn_params != null {
        let n: int = template.fn_params.len();
        if call.args.len() < n { n = call.args.len(); }
        for let i: int = 0; i < n; i++ {
            let p: Param = template.fn_params.get(i);
            let a: Expr = call.args.get(i);
            let at: *Type = infer_for_codegen(g, &a);
            if at != null && p.ty != null {
                unify_for_inference(p.ty, at, template.type_params, bindings);
            }
        }
    }

    // Build args in declared param order.
    let derived: *Vector<Type> = Vector::new();
    let mut all: bool = true;
    if template.type_params != null {
        for let i: int = 0; i < template.type_params.len(); i++ {
            let tn: string = template.type_params.get(i);
            if bindings.contains(tn) {
                derived.push(bindings.get(tn));
            } else {
                all = false;
            }
        }
    }
    if !all || derived.len() == 0 {
        bindings.free();
        return false;
    }

    let mangled: string = mangle_generic(gname, derived);
    callee.kind = EX_IDENT;
    callee.str_val = mangled;
    callee.field = "";
    if !g.emitted_monos.contains(mangled) {
        g.emitted_monos.insert(mangled, true);
        let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: derived };
        g.fn_mono_queue.push(entry);
    }
    bindings.free();
    return true;
}

// Recursively walks expr/stmt trees, calling try_mono_call on every generic
// call to queue monos and emit forward decls. Called as a pre-pass before
// emitting any fn body so forward decls don't interleave with code.
// For an EX_CALL `e`, return the declared type of the i-th formal parameter,
// or null when the callee isn't a known regular fn / impl method. Lets the
// prescan propagate `*Vector<int>` down into `take(Vector::new())` so the
// generic ctor monomorphizes from the surrounding context.
fn callee_param_ty(g: *CG, e: *Expr, i: int) -> *Type {
    if e == null || e.lhs == null { return null; }
    let callee: *Expr = e.lhs;
    if callee.kind == EX_IDENT && callee.str_val != null && g.fns.contains(callee.str_val) {
        let sig: Stmt = g.fns.get(callee.str_val);
        if sig.fn_params != null && i < sig.fn_params.len() {
            let p: Param = sig.fn_params.get(i);
            return p.ty;
        }
    }
    // Method call: `recv.method(args)` — look up the impl method and skip
    // self at index 0, so user arg index `i` maps to method param `i + 1`.
    if callee.kind == EX_MEMBER && callee.lhs != null {
        let rt: *Type = infer_for_codegen(g, callee.lhs);
        let stripped: *Type = strip_ptr(rt);
        if stripped != null && (stripped.kind == TY_NAMED || stripped.kind == TY_GENERIC) {
            let mname: string = stripped.name.concat("_").concat(callee.field);
            if g.fns.contains(mname) {
                let sig: Stmt = g.fns.get(mname);
                if sig.fn_params != null && (i + 1) < sig.fn_params.len() {
                    let p: Param = sig.fn_params.get(i + 1);
                    return p.ty;
                }
            }
            if g.generic_fns.contains(mname) {
                let sig: Stmt = g.generic_fns.get(mname);
                if sig.fn_params != null && (i + 1) < sig.fn_params.len() {
                    let p: Param = sig.fn_params.get(i + 1);
                    return p.ty;
                }
            }
        }
    }
    return null;
}

fn prescan_expr(g: *CG, e: *Expr, ret_hint: *Type) {
    if e == null { return; }
    if e.kind == EX_CALL {
        let _ok: bool = try_mono_call(g, e, ret_hint);
    }
    // Method call on generic receiver: also queue.
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER {
        let recv: *Expr = e.lhs.lhs;
        let method: string = e.lhs.field;
        let rt: *Type = infer_for_codegen(g, recv);
        let stripped: *Type = strip_ptr(rt);
        if stripped != null && stripped.kind == TY_GENERIC {
            let mname: string = stripped.name.concat("_").concat(method);
            if g.generic_fns.contains(mname) {
                let template: Stmt = g.generic_fns.get(mname);
                let mangled: string = mangle_generic(mname, stripped.args);
                if !g.emitted_monos.contains(mangled) {
                    g.emitted_monos.insert(mangled, true);
                    let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: stripped.args };
                    g.fn_mono_queue.push(entry);
                }
            }
        }
    }
    if e.lhs != null { prescan_expr(g, e.lhs, null); }
    if e.rhs != null { prescan_expr(g, e.rhs, null); }
    if e.operand != null { prescan_expr(g, e.operand, null); }
    if e.args != null {
        for let i: int = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            // Carry the formal param's declared type as the arg's expected
            // type so inline `Vector::new()` etc. monomorphize correctly.
            let mut arg_hint: *Type = null;
            if e.kind == EX_CALL { arg_hint = callee_param_ty(g, e, i); }
            prescan_expr(g, &a, arg_hint);
        }
    }
}

fn prescan_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    // `return X` carries the enclosing fn's return type as a hint so inline
    // generic ctors like `return Vector::new()` monomorphize correctly.
    if s.kind == ST_RETURN {
        if s.expr_value != null { prescan_expr(g, s.expr_value, g.current_ret_ty); }
        return;
    }
    if s.kind == ST_LET || s.kind == ST_CONST {
        // Declare in scope so receiver-type lookup works. When there's no
        // annotation, infer from the initializer (e.g. `let v = make()`
        // where `make` returns `*Vector<int>`).
        if s.let_ty != null { g.declare(s.name, s.let_ty); }
        else if s.let_value != null {
            let inferred: *Type = infer_for_codegen(g, s.let_value);
            if inferred != null { g.declare(s.name, inferred); }
        }
        if s.let_value != null { prescan_expr(g, s.let_value, s.let_ty); }
        // Auto-drop with `let v*` on a generic type: queue the free-method
        // mono so its forward decl is emitted before any user fn body.
        if s.kind == ST_LET && s.is_auto_owned && s.let_ty != null {
            let inner_ty: *Type = strip_ptr(s.let_ty);
            if inner_ty != null && inner_ty.kind == TY_GENERIC {
                let free_name: string = inner_ty.name.concat("_free");
                if g.generic_fns.contains(free_name) {
                    let mangled: string = mangle_generic(free_name, inner_ty.args);
                    if !g.emitted_monos.contains(mangled) {
                        g.emitted_monos.insert(mangled, true);
                        let template: Stmt = g.generic_fns.get(free_name);
                        let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: inner_ty.args };
                        g.fn_mono_queue.push(entry);
                    }
                }
            }
        }
        return;
    }
    if s.expr_value != null { prescan_expr(g, s.expr_value, null); }
    if s.cond != null { prescan_expr(g, s.cond, null); }
    if s.for_init != null { prescan_stmt(g, s.for_init); }
    if s.for_step != null { prescan_expr(g, s.for_step, null); }
    if s.then_body != null {
        for let i: int = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            prescan_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: int = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            prescan_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        g.scope.clear();
        if s.fn_params != null {
            for let i: int = 0; i < s.fn_params.len(); i++ {
                let p: Param = s.fn_params.get(i);
                g.declare(p.name, p.ty);
            }
        }
        let saved_ret: *Type = g.current_ret_ty;
        g.current_ret_ty = s.fn_ret_ty;
        for let i: int = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            prescan_stmt(g, &b);
        }
        g.current_ret_ty = saved_ret;
    }
    if s.impl_methods != null {
        for let i: int = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            prescan_stmt(g, &m);
        }
    }
}

fn emit_mono_forward_decl(g: *CG, mangled: string, template: *Stmt, args: *Vector<Type>) {
    let new_ret: *Type = subst_type(template.fn_ret_ty, template.type_params, args);
    print!(type_to_c(new_ret), " ", mangled, "(");
    if template.fn_params == null || template.fn_params.len() == 0 {
        print!("void");
    } else {
        for let j: int = 0; j < template.fn_params.len(); j++ {
            if j > 0 { print!(", "); }
            let pp: Param = template.fn_params.get(j);
            let pt: *Type = subst_type(pp.ty, template.type_params, args);
            print!(type_to_c(pt), " ", pp.name);
        }
    }
    println!(");");
}

// Unify a generic pattern type against a concrete type. Adds bindings for
// matching type vars listed in `params`. Returns false on mismatch (currently
// permissive: doesn't fail, just collects what it can).
fn unify_for_inference(pat: *Type, actual: *Type, params: *Vector<string>, bindings: *HashMap<Type>) {
    if pat == null { return; }
    if actual == null { return; }
    if pat.kind == TY_NAMED {
        // Type var?
        if params != null {
            for let i: int = 0; i < params.len(); i++ {
                if pat.name.eq(params.get(i)) {
                    if !bindings.contains(pat.name) {
                        bindings.insert(pat.name, *actual);
                    }
                    return;
                }
            }
        }
    }
    if pat.kind == TY_POINTER && actual.kind == TY_POINTER {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_BORROW && actual.kind == TY_BORROW {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_BORROW_MUT && actual.kind == TY_BORROW_MUT {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_SLICE && actual.kind == TY_SLICE {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_GENERIC && actual.kind == TY_GENERIC {
        if pat.name.eq(actual.name) && pat.args != null && actual.args != null
            && pat.args.len() == actual.args.len() {
            for let i: int = 0; i < pat.args.len(); i++ {
                let pa: Type = pat.args.get(i);
                let aa: Type = actual.args.get(i);
                unify_for_inference(&pa, &aa, params, bindings);
            }
        }
    }
}

// Recursive type substitution: walk t, replacing Type::Named(n) with the
// matching arg from `params -> args` mapping.
fn subst_type(t: *Type, params: *Vector<string>, args: *Vector<Type>) -> *Type {
    if t == null { return null; }
    if t.kind == TY_NAMED {
        if params != null {
            for let i: int = 0; i < params.len(); i++ {
                if t.name.eq(params.get(i)) {
                    let a: Type = args.get(i);
                    let p: *Type = malloc(sizeof(Type)) as *Type;
                    *p = a;
                    return p;
                }
            }
        }
        return t;
    }
    if t.kind == TY_POINTER { return ty_pointer(subst_type(t.inner, params, args)); }
    if t.kind == TY_BORROW {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW; p.inner = subst_type(t.inner, params, args);
        return p;
    }
    if t.kind == TY_BORROW_MUT {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW_MUT; p.inner = subst_type(t.inner, params, args);
        return p;
    }
    if t.kind == TY_SLICE {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_SLICE; p.inner = subst_type(t.inner, params, args);
        return p;
    }
    if t.kind == TY_GENERIC {
        let new_args: *Vector<Type> = Vector::new();
        if t.args != null {
            for let i: int = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                let na: *Type = subst_type(&a, params, args);
                if na != null { new_args.push(*na); }
            }
        }
        return ty_generic(t.name, new_args);
    }
    return t;
}

// Substitute type params in an expression. Walks structurally and also
// rewrites EX_STRUCT_LIT for known generic structs (so `Box{}` inside a mono
// body becomes `Box__int{}`).
fn subst_expr(e: *Expr, params: *Vector<string>, args: *Vector<Type>, gs: *HashMap<Stmt>) -> *Expr {
    if e == null { return null; }
    let n: *Expr = calloc(1, sizeof(Expr)) as *Expr;
    *n = *e;
    if e.cast_to != null { n.cast_to = subst_type(e.cast_to, params, args); }
    if e.lhs != null { n.lhs = subst_expr(e.lhs, params, args, gs); }
    if e.rhs != null { n.rhs = subst_expr(e.rhs, params, args, gs); }
    if e.operand != null { n.operand = subst_expr(e.operand, params, args, gs); }
    if e.args != null {
        let new_args: *Vector<Expr> = Vector::new();
        for let i: int = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            let nu: *Expr = subst_expr(&a, params, args, gs);
            if nu != null { new_args.push(*nu); }
        }
        n.args = new_args;
    }
    // Rewrite struct lit type_name when matches a known generic struct AND
    // the substitution provides as many args as the struct expects.
    if e.kind == EX_STRUCT_LIT && gs != null && gs.contains(e.str_val) {
        let template: Stmt = gs.get(e.str_val);
        if template.type_params != null && args != null
           && template.type_params.len() == args.len() {
            n.str_val = mangle_generic(e.str_val, args);
        }
    }
    return n;
}

fn subst_stmt(s: *Stmt, params: *Vector<string>, args: *Vector<Type>, gs: *HashMap<Stmt>) -> *Stmt {
    if s == null { return null; }
    let n: *Stmt = calloc(1, sizeof(Stmt)) as *Stmt;
    *n = *s;
    if s.let_ty != null { n.let_ty = subst_type(s.let_ty, params, args); }
    if s.let_value != null { n.let_value = subst_expr(s.let_value, params, args, gs); }
    if s.expr_value != null { n.expr_value = subst_expr(s.expr_value, params, args, gs); }
    if s.cond != null { n.cond = subst_expr(s.cond, params, args, gs); }
    if s.for_init != null { n.for_init = subst_stmt(s.for_init, params, args, gs); }
    if s.for_step != null { n.for_step = subst_expr(s.for_step, params, args, gs); }
    if s.fn_ret_ty != null { n.fn_ret_ty = subst_type(s.fn_ret_ty, params, args); }
    if s.then_body != null {
        let nb: *Vector<Stmt> = Vector::new();
        for let i: int = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            let nu: *Stmt = subst_stmt(&b, params, args, gs);
            if nu != null { nb.push(*nu); }
        }
        n.then_body = nb;
    }
    if s.else_body != null {
        let nb: *Vector<Stmt> = Vector::new();
        for let i: int = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            let nu: *Stmt = subst_stmt(&b, params, args, gs);
            if nu != null { nb.push(*nu); }
        }
        n.else_body = nb;
    }
    if s.fn_body != null {
        let nb: *Vector<Stmt> = Vector::new();
        for let i: int = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            let nu: *Stmt = subst_stmt(&b, params, args, gs);
            if nu != null { nb.push(*nu); }
        }
        n.fn_body = nb;
    }
    return n;
}

fn op_to_c(op: int) -> string {
    if op == OP_ADD { return "+"; }
    if op == OP_SUB { return "-"; }
    if op == OP_MUL { return "*"; }
    if op == OP_DIV { return "/"; }
    if op == OP_MOD { return "%"; }
    if op == OP_EQ  { return "=="; }
    if op == OP_NE  { return "!="; }
    if op == OP_LT  { return "<"; }
    if op == OP_LE  { return "<="; }
    if op == OP_GT  { return ">"; }
    if op == OP_GE  { return ">="; }
    if op == OP_AND { return "&&"; }
    if op == OP_OR  { return "||"; }
    if op == OP_BIT_AND { return "&"; }
    if op == OP_BIT_OR  { return "|"; }
    if op == OP_BIT_XOR { return "^"; }
    if op == OP_SHL { return "<<"; }
    if op == OP_SHR { return ">>"; }
    if op == OP_ASSIGN       { return "="; }
    if op == OP_PLUS_ASSIGN  { return "+="; }
    if op == OP_MINUS_ASSIGN { return "-="; }
    if op == OP_STAR_ASSIGN  { return "*="; }
    if op == OP_SLASH_ASSIGN { return "/="; }
    return "?";
}

fn unop_to_c(op: int) -> string {
    if op == UN_NEG { return "-"; }
    if op == UN_NOT { return "!"; }
    if op == UN_BIT_NOT { return "~"; }
    if op == UN_DEREF { return "*"; }
    if op == UN_ADDR { return "&"; }
    if op == UN_ADDR_MUT { return "&"; }
    return "?";
}

// ---- printing helpers (just print! to stdout) ----------------------------

fn ind(n: int) {
    for let i: int = 0; i < n; i++ { print!("    "); }
}

// ---- expressions ---------------------------------------------------------

pub fn emit_expr(g: *CG, e: *Expr) {
    if e == null { print!("/* null */"); return; }
    if e.kind == EX_INT { print!(e.int_val); return; }
    if e.kind == EX_FLOAT { print!(e.int_val); return; }   // float not modelled in payload yet
    if e.kind == EX_STRING { print!("\""); print!(e.str_val); print!("\""); return; }
    if e.kind == EX_CHAR {
        // Emit as `(char)NNN` decimal — C interprets `'\xNN'` as hex digits,
        // not decimal, so a decimal int_val would silently re-encode.
        print!("(char)"); print!(e.int_val); return;
    }
    if e.kind == EX_BOOL { if e.bool_val { print!("true"); } else { print!("false"); } return; }
    if e.kind == EX_NULL { print!("NULL"); return; }
    if e.kind == EX_IDENT { print!(e.str_val); return; }
    if e.kind == EX_BINARY {
        print!("(");
        emit_expr(g, e.lhs);
        print!(" ", op_to_c(e.op_code), " ");
        emit_expr(g, e.rhs);
        print!(")");
        return;
    }
    if e.kind == EX_UNARY {
        if e.op_code == UN_TRY {
            // Postfix `?`: GCC stmt-expr that unpacks a Result<T> in the
            // current fn whose ret-type is Result<U>. On err, return
            // a wrapped err of the outer type. On ok, evaluate to the inner val.
            let inner_ty: *Type = infer_for_codegen(g, e.operand);
            if inner_ty == null || inner_ty.kind != TY_RESULT
                || g.current_ret_ty == null || g.current_ret_ty.kind != TY_RESULT {
                print!("/* invalid `?` */ 0");
                return;
            }
            let m_in: string = mangle_type(inner_ty.inner);
            let m_out: string = mangle_type(g.current_ret_ty.inner);
            print!("({ __glide_result_".concat(m_in).concat("_t __r = ("));
            emit_expr(g, e.operand);
            print!("); if (!__r.ok) return __glide_err_".concat(m_out).concat("(__r.err); __r.val; })"));
            return;
        }
        print!("(".concat(unop_to_c(e.op_code)));
        emit_expr(g, e.operand);
        print!(")");
        return;
    }
    if e.kind == EX_ASSIGN {
        print!("(");
        emit_expr(g, e.lhs);
        print!(" ", op_to_c(e.op_code), " ");
        emit_expr(g, e.rhs);
        print!(")");
        return;
    }
    if e.kind == EX_CALL {
        // Enum ctor: `Shape::Circle(5)` → struct lit.
        if e.lhs != null && e.lhs.kind == EX_PATH && g.enums.contains(e.lhs.str_val) {
            let ename: string = e.lhs.str_val;
            let vname: string = e.lhs.field;
            print!("((");
            print!(ename);
            print!("){.tag = ");
            print!(ename.concat("_").concat(vname));
            if e.args != null && e.args.len() > 0 {
                if e.args.len() == 1 {
                    print!(", .data.v_");
                    print!(vname);
                    print!(" = ");
                    let a: Expr = e.args.get(0);
                    emit_expr(g, &a);
                } else {
                    print!(", .data.v_");
                    print!(vname);
                    print!(" = {");
                    for let i: int = 0; i < e.args.len(); i++ {
                        if i > 0 { print!(", "); }
                        let a: Expr = e.args.get(i);
                        emit_expr(g, &a);
                    }
                    print!("}");
                }
            }
            print!("})");
            return;
        }

        // ---- chan builtins: make_chan / send / recv / close ----
        if e.lhs != null && e.lhs.kind == EX_IDENT && e.args != null {
            let cname: string = e.lhs.str_val;
            if cname.eq("send") && e.args.len() == 2 {
                let c0: Expr = e.args.get(0);
                let ct: *Type = infer_for_codegen(g, &c0);
                if ct != null && ct.kind == TY_GENERIC && ct.name.eq("chan") && ct.args != null && ct.args.len() > 0 {
                    let inner: Type = ct.args.get(0);
                    let m: string = mangle_type(&inner);
                    print!("__glide_send_".concat(m).concat("("));
                    emit_expr(g, &c0);
                    print!(", ");
                    let v: Expr = e.args.get(1);
                    emit_expr(g, &v);
                    print!(")");
                    return;
                }
            }
            if cname.eq("recv") && e.args.len() == 1 {
                let c0: Expr = e.args.get(0);
                let ct: *Type = infer_for_codegen(g, &c0);
                if ct != null && ct.kind == TY_GENERIC && ct.name.eq("chan") && ct.args != null && ct.args.len() > 0 {
                    let inner: Type = ct.args.get(0);
                    let m: string = mangle_type(&inner);
                    print!("__glide_recv_".concat(m).concat("("));
                    emit_expr(g, &c0);
                    print!(")");
                    return;
                }
            }
            if cname.eq("close") && e.args.len() == 1 {
                let c0: Expr = e.args.get(0);
                let ct: *Type = infer_for_codegen(g, &c0);
                if ct != null && ct.kind == TY_GENERIC && ct.name.eq("chan") && ct.args != null && ct.args.len() > 0 {
                    let inner: Type = ct.args.get(0);
                    let m: string = mangle_type(&inner);
                    print!("__glide_close_".concat(m).concat("("));
                    emit_expr(g, &c0);
                    print!(")");
                    return;
                }
            }
            if cname.eq("unwrap") && e.args.len() == 1 {
                let r0: Expr = e.args.get(0);
                let rt: *Type = infer_for_codegen(g, &r0);
                if rt != null && rt.kind == TY_RESULT {
                    let m: string = mangle_type(rt.inner);
                    print!("__glide_unwrap_".concat(m).concat("("));
                    emit_expr(g, &r0);
                    print!(")");
                    return;
                }
            }
        }

        // Try generic monomorphization based on arg types (no ret-hint here).
        let _mono_ok: bool = try_mono_call(g, e, null);

        // Method call: callee is a Member. Rewrite to Type_method(receiver, args).
        if e.lhs != null && e.lhs.kind == EX_MEMBER {
            let recv: *Expr = e.lhs.lhs;
            let method: string = e.lhs.field;
            let recv_ty: *Type = infer_for_codegen(g, recv);
            let stripped: *Type = strip_ptr(recv_ty);

            // Generic method on a generic receiver (e.g. `v.push(x)` on
            // `*Vector<int>`). The receiver's type args bind the impl's
            // type params; mangle accordingly.
            if stripped != null && stripped.kind == TY_GENERIC {
                let base: string = stripped.name;
                let mname: string = base.concat("_").concat(method);
                if g.generic_fns.contains(mname) {
                    let template: Stmt = g.generic_fns.get(mname);
                    // Receiver supplies the impl's type args directly.
                    let mangled: string = mangle_generic(mname, stripped.args);
                    if !g.emitted_monos.contains(mangled) {
                        g.emitted_monos.insert(mangled, true);
                        let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: stripped.args };
                        g.fn_mono_queue.push(entry);
                    }
                    print!(mangled);
                    print!("(");
                    let needs_addr: bool = recv_ty != null
                        && recv_ty.kind != TY_POINTER
                        && recv_ty.kind != TY_BORROW
                        && recv_ty.kind != TY_BORROW_MUT;
                    if needs_addr { print!("&"); }
                    emit_expr(g, recv);
                    if e.args != null {
                        for let i: int = 0; i < e.args.len(); i++ {
                            print!(", ");
                            let a: Expr = e.args.get(i);
                            emit_expr(g, &a);
                        }
                    }
                    print!(")");
                    return;
                }
            }

            if stripped != null && stripped.kind == TY_NAMED {
                let mut prefix: string = stripped.name;
                let mut fn_name: string = "";
                if is_stdlib_primitive(stripped.name) {
                    fn_name = "__glide_".concat(prefix).concat("_").concat(method);
                } else {
                    fn_name = prefix.concat("_").concat(method);
                }
                print!(fn_name);
                print!("(");
                // Primitives are passed by value (no auto-`&`).
                let is_prim: bool = is_stdlib_primitive(stripped.name);
                let needs_addr: bool = !is_prim && recv_ty != null
                    && recv_ty.kind != TY_POINTER
                    && recv_ty.kind != TY_BORROW
                    && recv_ty.kind != TY_BORROW_MUT;
                if needs_addr { print!("&"); }
                emit_expr(g, recv);
                if e.args != null {
                    for let i: int = 0; i < e.args.len(); i++ {
                        print!(", ");
                        let a: Expr = e.args.get(i);
                        emit_expr(g, &a);
                    }
                }
                print!(")");
                return;
            }
            // Fallback: emit as plain member call.
        }
        // Indirect call through a fn-ptr (void*) — needs an inline cast in C.
        let callee_ty: *Type = infer_for_codegen(g, e.lhs);
        if callee_ty != null && callee_ty.kind == TY_FNPTR {
            print!("(("); print!(fnptr_cast_str(callee_ty)); print!(")");
            emit_expr(g, e.lhs);
            print!(")");
        } else {
            emit_expr(g, e.lhs);
        }
        print!("(");
        if e.args != null {
            for let i: int = 0; i < e.args.len(); i++ {
                if i > 0 { print!(", "); }
                let a: Expr = e.args.get(i);
                emit_expr(g, &a);
            }
        }
        print!(")");
        return;
    }
    if e.kind == EX_MEMBER {
        // Auto-deref for pointer receivers: `p.x` -> `p->x` for *T,
        // but C also allows `(*p).x`. Emit `->` when receiver is pointer.
        let recv_ty: *Type = infer_for_codegen(g, e.lhs);
        if recv_ty != null
            && (recv_ty.kind == TY_POINTER
                || recv_ty.kind == TY_BORROW
                || recv_ty.kind == TY_BORROW_MUT) {
            print!("(");
            emit_expr(g, e.lhs);
            print!("->", e.field, ")");
            return;
        }
        print!("(");
        emit_expr(g, e.lhs);
        print!(".", e.field, ")");
        return;
    }
    if e.kind == EX_INDEX {
        emit_expr(g, e.lhs);
        print!("[");
        emit_expr(g, e.rhs);
        print!("]");
        return;
    }
    if e.kind == EX_CAST {
        print!("((", type_to_c(e.cast_to), ")");
        emit_expr(g, e.lhs);
        print!(")");
        return;
    }
    if e.kind == EX_SIZEOF {
        print!("sizeof(", type_to_c(e.cast_to), ")");
        return;
    }
    if e.kind == EX_FNEXPR {
        // Lift to a uniquely-named top-level fn; expression evaluates to its
        // address (which decays to a fn pointer in C).
        let id: int = g.anon_count;
        g.anon_count = id + 1;
        let name: string = "__glide_anon_".concat(int_to_str(id));
        let af: AnonFn = AnonFn {
            name: name,
            params: e.fn_expr_params,
            ret_ty: e.cast_to,
            body: e.fn_expr_body,
        };
        g.anon_fns.push(af);
        print!(name);
        return;
    }
    if e.kind == EX_PATH {
        print!(e.str_val.concat("_").concat(e.field));
        return;
    }
    if e.kind == EX_POSTINC { emit_expr(g, e.lhs); print!("++"); return; }
    if e.kind == EX_POSTDEC { emit_expr(g, e.lhs); print!("--"); return; }
    if e.kind == EX_MACRO {
        if e.str_val.eq("println") || e.str_val.eq("print") {
            print!("printf(\"");
            // Build a format string by walking args, joining with spaces.
            if e.args != null {
                for let i: int = 0; i < e.args.len(); i++ {
                    if i > 0 { print!(" "); }
                    let a: Expr = e.args.get(i);
                    let at: *Type = infer_for_codegen(g, &a);
                    print!(format_spec_for(at));
                }
            }
            if e.str_val.eq("println") { print!("\\n"); }
            print!("\"");
            // Then emit args (with bool→string conversion).
            if e.args != null {
                for let i: int = 0; i < e.args.len(); i++ {
                    print!(", ");
                    let a: Expr = e.args.get(i);
                    let at: *Type = infer_for_codegen(g, &a);
                    if at != null && at.kind == TY_NAMED && at.name.eq("bool") {
                        print!("__glide_bool_to_string(");
                        emit_expr(g, &a);
                        print!(")");
                    } else {
                        emit_expr(g, &a);
                    }
                }
            }
            print!(")");
            return;
        }
        if e.str_val.eq("format") {
            print!("__glide_format(");
            // First arg: format string with {} converted to appropriate %fmt.
            if e.args != null && e.args.len() > 0 {
                let first: Expr = e.args.get(0);
                if first.kind == EX_STRING {
                    print!("\"");
                    let raw: string = first.str_val;
                    let mut arg_idx: int = 1;
                    let n: int = raw.len();
                    let mut i: int = 0;
                    while i < n {
                        let c: char = raw.at(i);
                        if c.to_int() == 123 && i + 1 < n && raw.at(i + 1).to_int() == 125 {
                            if e.args != null && arg_idx < e.args.len() {
                                let a: Expr = e.args.get(arg_idx);
                                let at: *Type = infer_for_codegen(g, &a);
                                print!(format_spec_for(at));
                            } else {
                                print!("%s");
                            }
                            arg_idx = arg_idx + 1;
                            i = i + 2;
                        } else {
                            // emit char literal-safe
                            if c.to_int() == 34 { print!("\\\""); }
                            else if c.to_int() == 92 { print!("\\\\"); }
                            else { print!(c); }
                            i = i + 1;
                        }
                    }
                    print!("\"");
                } else {
                    emit_expr(g, &first);
                }
                for let j: int = 1; j < e.args.len(); j++ {
                    print!(", ");
                    let a: Expr = e.args.get(j);
                    emit_expr(g, &a);
                }
            }
            print!(")");
            return;
        }
        print!("/* macro ", e.str_val, " */ 0");
        return;
    }
    if e.kind == EX_STRUCT_LIT {
        print!("((", e.str_val, "){");
        if e.field_names != null && e.args != null {
            for let i: int = 0; i < e.args.len(); i++ {
                if i > 0 { print!(", "); }
                print!(".", e.field_names.get(i), " = ");
                let v: Expr = e.args.get(i);
                emit_expr(g, &v);
            }
        }
        print!("})");
        return;
    }
    print!("/* unknown expr ", e.kind, " */ 0");
}

// ---- statements ----------------------------------------------------------

pub fn emit_stmt(g: *CG, s: *Stmt, depth: int) {
    if s == null { return; }
    if s.kind == ST_LET || s.kind == ST_CONST {
        // Auto-drop modes:
        //   struct_lit_auto: `let p: *T = T { ... }` rewrites RHS to malloc+init.
        //   explicit_auto: `let v* = expr` (explicit `*` after binding name).
        // Both push a cleanup expression onto the defer stack: a method call
        // `v.free()` if the type defines one, otherwise `free(v as *void)`.
        let mut struct_lit_auto: bool = false;
        if s.kind == ST_LET && s.let_ty != null && s.let_ty.kind == TY_POINTER
           && s.let_value != null && s.let_value.kind == EX_STRUCT_LIT {
            if s.let_ty.inner != null && s.let_ty.inner.kind == TY_NAMED {
                if s.let_ty.inner.name.eq(s.let_value.str_val) {
                    struct_lit_auto = true;
                }
            }
        }
        let auto_owned: bool = struct_lit_auto || s.is_auto_owned;
        // ---- pre-pass: detect generic fn call BEFORE we emit anything,
        //      since we may need to print a forward decl on its own line.

        // Generic struct literal hint: `let b: Box<int> = Box { ... }` →
        // rewrite the struct lit type_name to the mangled mono name.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_GENERIC {
            if s.let_value.kind == EX_STRUCT_LIT
                && s.let_value.str_val.eq(s.let_ty.name) {
                s.let_value.str_val = mangle_generic(s.let_ty.name, s.let_ty.args);
            }
        }
        // make_chan(cap) hint: rewrite to __glide_make_chan_<m>(cap) using let-annot.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_GENERIC
            && s.let_ty.name.eq("chan") && s.let_ty.args != null && s.let_ty.args.len() > 0
            && s.let_value.kind == EX_CALL && s.let_value.lhs != null
            && s.let_value.lhs.kind == EX_IDENT
            && s.let_value.lhs.str_val.eq("make_chan") {
            let inner: Type = s.let_ty.args.get(0);
            let m: string = mangle_type(&inner);
            s.let_value.lhs.str_val = "__glide_make_chan_".concat(m);
        }
        // ok(v)/err(s) hint: rewrite to __glide_ok_<m>/__glide_err_<m> using let-annot `!T`.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_RESULT
            && s.let_value.kind == EX_CALL && s.let_value.lhs != null
            && s.let_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(s.let_ty.inner);
            if s.let_value.lhs.str_val.eq("ok") {
                s.let_value.lhs.str_val = "__glide_ok_".concat(m);
            }
            if s.let_value.lhs.str_val.eq("err") {
                s.let_value.lhs.str_val = "__glide_err_".concat(m);
            }
        }
        // Generic fn call mono attempt — uses let-annot as ret-hint plus args.
        if s.let_value != null && s.let_value.kind == EX_CALL {
            let _ok: bool = try_mono_call(g, s.let_value, s.let_ty);
        }

        // ---- now emit the let stmt itself ----
        ind(depth);
        if s.let_ty != null {
            print!(type_to_c(s.let_ty), " ", s.name);
            g.declare(s.name, s.let_ty);
        } else if s.let_value != null {
            // Try to infer from value. If the value is an Ident referencing
            // a lifted anon fn, use void* (fn-pointer slot).
            let mut handled: bool = false;
            if s.let_value.kind == EX_IDENT {
                for let k: int = 0; k < g.anon_fns.len(); k++ {
                    let af: AnonFn = g.anon_fns.get(k);
                    if af.name.eq(s.let_value.str_val) {
                        print!("void* ", s.name);
                        let void_ptr: *Type = ty_pointer(ty_named("void"));
                        g.declare(s.name, void_ptr);
                        handled = true;
                        break;
                    }
                }
            }
            if !handled {
                let vt: *Type = infer_for_codegen(g, s.let_value);
                if vt != null {
                    print!(type_to_c(vt), " ", s.name);
                    g.declare(s.name, vt);
                } else {
                    print!("/* infer */ int ", s.name);
                }
            }
        } else {
            print!("/* infer */ int ", s.name);
        }
        if struct_lit_auto {
            // T* p = malloc(sizeof(T)); *p = (T){...};
            print!(" = (");
            print!(type_to_c(s.let_ty));
            print!(")malloc(sizeof(");
            print!(type_to_c(s.let_ty.inner));
            print!("));");
            println!("");
            ind(depth);
            print!("*");
            print!(s.name);
            print!(" = ");
            emit_expr(g, s.let_value);
            println!(";");
        } else {
            if s.let_value != null {
                print!(" = ");
                emit_expr(g, s.let_value);
            }
            println!(";");
        }
        if auto_owned {
            // Decide cleanup: prefer `v.free()` method if type defines one
            // (e.g. Vector_free); otherwise libc `free(v as *void)`.
            let inner_ty: *Type = strip_ptr(s.let_ty);
            let mut method_name: string = "";
            let mut has_method: bool = false;
            if inner_ty != null && inner_ty.kind == TY_NAMED {
                method_name = inner_ty.name.concat("_free");
                if g.fns.contains(method_name) { has_method = true; }
            }
            if inner_ty != null && inner_ty.kind == TY_GENERIC {
                method_name = inner_ty.name.concat("_free");
                if g.generic_fns.contains(method_name) { has_method = true; }
            }
            if has_method {
                // Push `v.free()` (member call) onto defer; emit_expr will
                // dispatch through the existing method-on-receiver path,
                // including mono for generic receivers.
                let recv: *Expr = expr_ident(s.name, s.line, s.column);
                let mem: *Expr = expr_member(recv, "free");
                let no_args: *Vector<Expr> = Vector::new();
                let call: *Expr = expr_call(mem, no_args);
                g.auto_drop_stack.push(*call);
            } else {
                let free_call: *Expr = calloc(1, sizeof(Expr)) as *Expr;
                free_call.kind = EX_CALL;
                free_call.line = s.line;
                free_call.column = s.column;
                let callee: *Expr = expr_ident("free", s.line, s.column);
                free_call.lhs = callee;
                let args: *Vector<Expr> = Vector::new();
                let cast_arg: *Expr = expr_cast(expr_ident(s.name, s.line, s.column),
                                                 ty_pointer(ty_named("void")));
                args.push(*cast_arg);
                free_call.args = args;
                g.auto_drop_stack.push(*free_call);
            }
        }
        return;
    }
    if s.kind == ST_RETURN {
        // ok(v)/err(s) hint via current fn ret-type `!T`.
        if s.expr_value != null && g.current_ret_ty != null
            && g.current_ret_ty.kind == TY_RESULT
            && s.expr_value.kind == EX_CALL && s.expr_value.lhs != null
            && s.expr_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(g.current_ret_ty.inner);
            if s.expr_value.lhs.str_val.eq("ok") {
                s.expr_value.lhs.str_val = "__glide_ok_".concat(m);
            }
            if s.expr_value.lhs.str_val.eq("err") {
                s.expr_value.lhs.str_val = "__glide_err_".concat(m);
            }
        }
        // If there's a value AND there are pending cleanups (auto-drop or
        // explicit defer), capture the value in a temp BEFORE running cleanups
        // so e.g. `return v.get(0)` doesn't read freed memory after auto-drop
        // of v fires.
        let has_cleanup: bool = g.defer_stack.len() > 0 || g.auto_drop_stack.len() > 0;
        if s.expr_value != null && has_cleanup {
            ind(depth);
            print!("__typeof__(");
            emit_expr(g, s.expr_value);
            print!(") __glide_ret = ");
            emit_expr(g, s.expr_value);
            println!(";");
            g.emit_deferred_reverse(depth);
            ind(depth); println!("return __glide_ret;");
        } else {
            g.emit_deferred_reverse(depth);
            ind(depth);
            print!("return");
            if s.expr_value != null { print!(" "); emit_expr(g, s.expr_value); }
            println!(";");
        }
        return;
    }
    if s.kind == ST_DEFER {
        if s.expr_value != null { g.defer_stack.push(*s.expr_value); }
        return;
    }
    if s.kind == ST_SPAWN {
        let id: int = g.spawn_count;
        g.spawn_count = id + 1;
        let ids: string = int_to_str(id);
        let an: string = "__glide_spawn_args_".concat(ids);
        let call: *Expr = s.expr_value;
        ind(depth); println!("{");
        ind(depth + 1);
        println!(an.concat("* __args = (").concat(an).concat("*)malloc(sizeof(").concat(an).concat("));"));
        if call != null && call.args != null {
            for let i: int = 0; i < call.args.len(); i++ {
                ind(depth + 1);
                print!("__args->a".concat(int_to_str(i)).concat(" = "));
                let a: Expr = call.args.get(i);
                emit_expr(g, &a);
                println!(";");
            }
        }
        ind(depth + 1); println!("pthread_t __tid;");
        ind(depth + 1); println!("pthread_create(&__tid, NULL, __glide_spawn_stub_".concat(ids).concat(", __args);"));
        ind(depth + 1); println!("pthread_detach(__tid);");
        ind(depth); println!("}");
        return;
    }
    if s.kind == ST_EXPR {
        ind(depth);
        emit_expr(g, s.expr_value);
        println!(";");
        return;
    }
    if s.kind == ST_BREAK { ind(depth); println!("break;"); return; }
    if s.kind == ST_CONTINUE { ind(depth); println!("continue;"); return; }
    if s.kind == ST_IF {
        ind(depth); print!("if (");
        emit_expr(g, s.cond);
        println!(") {");
        if s.then_body != null {
            let saved: int = g.auto_drop_stack.len();
            for let i: int = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth);
        if s.else_body != null {
            println!("} else {");
            let saved: int = g.auto_drop_stack.len();
            for let i: int = 0; i < s.else_body.len(); i++ {
                let b: Stmt = s.else_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
            ind(depth); println!("}");
        } else {
            println!("}");
        }
        return;
    }
    if s.kind == ST_WHILE {
        ind(depth); print!("while (");
        emit_expr(g, s.cond);
        println!(") {");
        if s.then_body != null {
            let saved: int = g.auto_drop_stack.len();
            for let i: int = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth); println!("}");
        return;
    }
    if s.kind == ST_FOR {
        ind(depth); print!("for (");
        if s.for_init != null {
            if s.for_init.kind == ST_LET {
                if s.for_init.let_ty != null {
                    print!(type_to_c(s.for_init.let_ty), " ", s.for_init.name);
                    g.declare(s.for_init.name, s.for_init.let_ty);
                } else {
                    // Untyped `for let i = 0; ...`: default to int and register
                    // it in scope so the body's `i` references type-resolve to
                    // int (otherwise printf-style macros emit `%p` → hex).
                    print!("int ", s.for_init.name);
                    g.declare(s.for_init.name, ty_named("int"));
                }
                if s.for_init.let_value != null {
                    print!(" = "); emit_expr(g, s.for_init.let_value);
                }
            } else {
                if s.for_init.expr_value != null { emit_expr(g, s.for_init.expr_value); }
            }
        }
        print!("; ");
        if s.cond != null { emit_expr(g, s.cond); }
        print!("; ");
        if s.for_step != null { emit_expr(g, s.for_step); }
        println!(") {");
        if s.then_body != null {
            let saved: int = g.auto_drop_stack.len();
            for let i: int = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth); println!("}");
        return;
    }
    if s.kind == ST_MATCH {
        // Compile to: { Type _m = scrut; switch (_m.tag) { case ENUM_VAR: ... } }
        ind(depth); println!("{");
        let scrut_ty: *Type = infer_for_codegen(g, s.scrutinee);
        let mut enum_name: string = "X";
        if scrut_ty != null && scrut_ty.kind == TY_NAMED { enum_name = scrut_ty.name; }
        ind(depth + 1); print!(enum_name, " __m = ");
        emit_expr(g, s.scrutinee);
        println!(";");
        ind(depth + 1); println!("switch (__m.tag) {");
        if s.arms != null {
            for let i: int = 0; i < s.arms.len(); i++ {
                let a: MatchArm = s.arms.get(i);
                ind(depth + 1);
                if a.variant.eq("_") { print!("default: "); }
                else {
                    print!("case ");
                    print!(enum_name.concat("_").concat(a.variant));
                    print!(": ");
                }
                println!("{");
                if a.bindings != null && a.bindings.len() > 0 {
                    if a.bindings.len() == 1 {
                        ind(depth + 2);
                        let payload: string = "__m.data.v_".concat(a.variant);
                        print!("__typeof__(");
                        print!(payload);
                        print!(") ");
                        print!(a.bindings.get(0));
                        print!(" = ");
                        print!(payload);
                        println!(";");
                    } else {
                        for let k: int = 0; k < a.bindings.len(); k++ {
                            ind(depth + 2);
                            let payload: string = "__m.data.v_".concat(a.variant);
                            print!("__typeof__(");
                            print!(payload); print!(".f"); print!(k);
                            print!(") ");
                            print!(a.bindings.get(k));
                            print!(" = ");
                            print!(payload); print!(".f"); print!(k);
                            println!(";");
                        }
                    }
                }
                if a.body != null {
                    for let k: int = 0; k < a.body.len(); k++ {
                        let bb: Stmt = a.body.get(k);
                        emit_stmt(g, &bb, depth + 2);
                    }
                }
                ind(depth + 1); println!("break; }");
            }
        }
        ind(depth + 1); println!("}");
        ind(depth); println!("}");
        return;
    }
    if s.kind == ST_BLOCK {
        ind(depth); println!("{");
        if s.then_body != null {
            let saved: int = g.auto_drop_stack.len();
            for let i: int = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth); println!("}");
        return;
    }
    ind(depth); println!("/* unknown stmt ", s.kind, " */");
}

// ---- top-level -----------------------------------------------------------

fn emit_fn_signature(s: *Stmt) {
    if s.name.eq("main") {
        print!("int main(int __glide_main_argc, char** __glide_main_argv)");
        return;
    }
    print!(type_to_c(s.fn_ret_ty), " ", s.name, "(");
    if s.fn_params == null || s.fn_params.len() == 0 {
        print!("void");
    } else {
        for let i: int = 0; i < s.fn_params.len(); i++ {
            if i > 0 { print!(", "); }
            let p: Param = s.fn_params.get(i);
            print!(type_to_c(p.ty), " ", p.name);
        }
    }
    print!(")");
}

// Walk an expr looking for `var.method(args)`. If found, try to resolve
// the impl-generic type params from the args. Returns the inferred
// concrete generic type (e.g. *Vector<int>) on success.
fn try_constrain_from_expr(g: *CG, e: *Expr, var: string, gen_name: string, tparams: *Vector<string>) -> *Type {
    if e == null { return null; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER
       && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT
       && e.lhs.lhs.str_val.eq(var) {
        let method: string = e.lhs.field;
        let mname: string = gen_name.concat("_").concat(method);
        if g.generic_fns.contains(mname) {
            let mtmpl: Stmt = g.generic_fns.get(mname);
            // For each tparam, find a method param (skipping self at index 0)
            // whose ty == Named(tparam). The corresponding user arg has the
            // concrete type. User args are e.args; method params after self
            // align 1:1 with them.
            if mtmpl.fn_params != null && e.args != null {
                let resolved: *Vector<Type> = Vector::new();
                let mut all: bool = true;
                for let pi: int = 0; pi < tparams.len(); pi++ {
                    let tp: string = tparams.get(pi);
                    let mut found: *Type = null;
                    for let j: int = 1; j < mtmpl.fn_params.len(); j++ {
                        let mp: Param = mtmpl.fn_params.get(j);
                        if mp.ty != null && mp.ty.kind == TY_NAMED && mp.ty.name.eq(tp) {
                            let arg_idx: int = j - 1;
                            if arg_idx < e.args.len() {
                                let a: Expr = e.args.get(arg_idx);
                                let at: *Type = infer_for_codegen(g, &a);
                                if at != null { found = at; break; }
                            }
                        }
                    }
                    if found == null { all = false; break; }
                    resolved.push(*found);
                }
                if all && resolved.len() > 0 {
                    return ty_pointer(ty_generic(gen_name, resolved));
                }
            }
        }
    }
    // Recurse into children.
    if e.lhs != null {
        let r: *Type = try_constrain_from_expr(g, e.lhs, var, gen_name, tparams);
        if r != null { return r; }
    }
    if e.rhs != null {
        let r: *Type = try_constrain_from_expr(g, e.rhs, var, gen_name, tparams);
        if r != null { return r; }
    }
    if e.operand != null {
        let r: *Type = try_constrain_from_expr(g, e.operand, var, gen_name, tparams);
        if r != null { return r; }
    }
    if e.args != null {
        for let i: int = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            let r: *Type = try_constrain_from_expr(g, &a, var, gen_name, tparams);
            if r != null { return r; }
        }
    }
    return null;
}

fn try_constrain_from_stmt(g: *CG, s: *Stmt, var: string, gen_name: string, tparams: *Vector<string>) -> *Type {
    if s == null { return null; }
    if s.let_value != null {
        let r: *Type = try_constrain_from_expr(g, s.let_value, var, gen_name, tparams);
        if r != null { return r; }
    }
    if s.expr_value != null {
        let r: *Type = try_constrain_from_expr(g, s.expr_value, var, gen_name, tparams);
        if r != null { return r; }
    }
    if s.cond != null {
        let r: *Type = try_constrain_from_expr(g, s.cond, var, gen_name, tparams);
        if r != null { return r; }
    }
    if s.for_step != null {
        let r: *Type = try_constrain_from_expr(g, s.for_step, var, gen_name, tparams);
        if r != null { return r; }
    }
    if s.then_body != null {
        for let i: int = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            let r: *Type = try_constrain_from_stmt(g, &b, var, gen_name, tparams);
            if r != null { return r; }
        }
    }
    if s.else_body != null {
        for let i: int = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            let r: *Type = try_constrain_from_stmt(g, &b, var, gen_name, tparams);
            if r != null { return r; }
        }
    }
    return null;
}

// Walk a stmt populating g.scope from any ST_LET it contains (recursively).
// Used so the type-inference pre-pass can resolve identifier references in
// nested blocks (e.g. `for let i: int = 0; ...; i++ { v.push(i * 10); }`).
fn populate_scope_from_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.kind == ST_LET || s.kind == ST_CONST {
        let mut ty: *Type = s.let_ty;
        // No annotation? Infer from the initializer so plain `let i = 0`
        // (typical in for-loops) registers `i: int` in the codegen scope —
        // otherwise printf-style macros default to `%p` and emit hex.
        if ty == null && s.let_value != null {
            ty = infer_for_codegen(g, s.let_value);
        }
        if ty != null { g.declare(s.name, ty); }
    }
    if s.for_init != null { populate_scope_from_stmt(g, s.for_init); }
    if s.then_body != null {
        for let i: int = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            populate_scope_from_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: int = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            populate_scope_from_stmt(g, &b);
        }
    }
}

fn try_resolve_open_let(g: *CG, s: *Stmt, body: *Vector<Stmt>, start: int) -> *Type {
    if s.let_ty != null { return null; }
    if s.let_value == null || s.let_value.kind != EX_CALL { return null; }
    let callee: *Expr = s.let_value.lhs;
    if callee == null { return null; }
    let mut gname: string = "";
    if callee.kind == EX_IDENT { gname = callee.str_val; }
    if callee.kind == EX_PATH { gname = callee.str_val.concat("_").concat(callee.field); }
    if gname.len() == 0 { return null; }
    if !g.generic_fns.contains(gname) { return null; }
    let template: Stmt = g.generic_fns.get(gname);
    if template.type_params == null || template.type_params.len() == 0 { return null; }
    if template.fn_ret_ty == null { return null; }
    let mut inner: *Type = template.fn_ret_ty;
    while inner != null && inner.kind == TY_POINTER {
        inner = inner.inner;
    }
    if inner == null || inner.kind != TY_GENERIC { return null; }
    let gen_base: string = inner.name;
    let n: int = body.len();
    for let j: int = start + 1; j < n; j++ {
        let s2: Stmt = body.get(j);
        let r: *Type = try_constrain_from_stmt(g, &s2, s.name, gen_base, template.type_params);
        if r != null { return r; }
    }
    return null;
}

// Pre-pass: for each `let v = Generic::new()` (no annot) anywhere in the fn,
// resolve T from the first subsequent use of v in the same body and backfill
// s.let_ty. Recurses into nested if/for/while bodies.
fn infer_let_types(g: *CG, body: *Vector<Stmt>) {
    if body == null { return; }
    // Pre-populate scope with all annotated lets (recursing) so identifier
    // inference works inside nested blocks.
    for let k: int = 0; k < body.len(); k++ {
        let sk: Stmt = body.get(k);
        populate_scope_from_stmt(g, &sk);
    }
    let n: int = body.len();
    for let i: int = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET {
            let resolved: *Type = try_resolve_open_let(g, &s, body, i);
            if resolved != null {
                s.let_ty = resolved;
                body.set(i, s);
                g.declare(s.name, resolved);
            }
        }
        // Recurse into nested bodies for lets buried inside loops / branches.
        if s.then_body != null { infer_let_types(g, s.then_body); }
        if s.else_body != null { infer_let_types(g, s.else_body); }
    }
}

fn infer_let_types_in_program(g: *CG, program: *Vector<Stmt>) {
    let n: int = program.len();
    for let i: int = 0; i < n; i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            // Set up a fresh scope with this fn's params so identifier
            // inference works during the pre-pass.
            g.scope.clear();
            if s.fn_params != null {
                for let k: int = 0; k < s.fn_params.len(); k++ {
                    let p: Param = s.fn_params.get(k);
                    g.declare(p.name, p.ty);
                }
            }
            infer_let_types(g, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: int = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null {
                    g.scope.clear();
                    if m.fn_params != null {
                        for let k: int = 0; k < m.fn_params.len(); k++ {
                            let p: Param = m.fn_params.get(k);
                            g.declare(p.name, p.ty);
                        }
                    }
                    infer_let_types(g, m.fn_body);
                }
            }
        }
    }
    // Restore empty scope for the regular emit pipeline.
    g.scope.clear();
}

fn emit_fn(g: *CG, s: *Stmt) {
    emit_fn_signature(s);
    println!(" {");
    if s.name.eq("main") {
        println!("    __glide_args_init(__glide_main_argc, __glide_main_argv);");
    }
    g.scope.clear();
    let saved_ret: *Type = g.current_ret_ty;
    g.current_ret_ty = s.fn_ret_ty;
    // Reset defer + auto-drop stacks for this fn.
    let saved_defer: *Vector<Expr> = g.defer_stack;
    let saved_drop: *Vector<Expr> = g.auto_drop_stack;
    let new_defer: *Vector<Expr> = Vector::new();
    let new_drop: *Vector<Expr> = Vector::new();
    g.defer_stack = new_defer;
    g.auto_drop_stack = new_drop;
    if s.fn_params != null {
        for let i: int = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            g.declare(p.name, p.ty);
        }
    }
    if s.fn_body != null {
        for let i: int = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            emit_stmt(g, &b, 1);
        }
    }
    // Flush any deferred exprs that didn't hit a return (e.g. fall-through fn end).
    g.emit_deferred_reverse(1);
    g.defer_stack = saved_defer;
    g.auto_drop_stack = saved_drop;
    g.current_ret_ty = saved_ret;
    println!("}");
}

fn emit_impl(g: *CG, s: *Stmt) {
    if s.impl_methods == null { return; }
    let prefix: string = "X";
    if s.impl_target != null && s.impl_target.kind == TY_NAMED {
        prefix = s.impl_target.name;
    }
    for let i: int = 0; i < s.impl_methods.len(); i++ {
        let m: Stmt = s.impl_methods.get(i);
        // Mangle method name: Type_method.
        let mangled: string = prefix.concat("_").concat(m.name);
        // Emit a fn with mangled name.
        let mut saved_name: string = m.name;
        // We can't mutate the Stmt easily here; emit signature inline then body.
        print!(type_to_c(m.fn_ret_ty), " ", mangled, "(");
        if m.fn_params == null || m.fn_params.len() == 0 {
            print!("void");
        } else {
            for let j: int = 0; j < m.fn_params.len(); j++ {
                if j > 0 { print!(", "); }
                let p: Param = m.fn_params.get(j);
                print!(type_to_c(p.ty), " ", p.name);
            }
        }
        println!(") {");
        g.scope.clear();
        let saved_defer: *Vector<Expr> = g.defer_stack;
        let saved_drop: *Vector<Expr> = g.auto_drop_stack;
        let nd: *Vector<Expr> = Vector::new();
        let nadr: *Vector<Expr> = Vector::new();
        g.defer_stack = nd;
        g.auto_drop_stack = nadr;
        if m.fn_params != null {
            for let j: int = 0; j < m.fn_params.len(); j++ {
                let p: Param = m.fn_params.get(j);
                g.declare(p.name, p.ty);
            }
        }
        if m.fn_body != null {
            for let j: int = 0; j < m.fn_body.len(); j++ {
                let b: Stmt = m.fn_body.get(j);
                emit_stmt(g, &b, 1);
            }
        }
        g.emit_deferred_reverse(1);
        g.defer_stack = saved_defer;
        g.auto_drop_stack = saved_drop;
        println!("}");
        println!("");
    }
}

fn emit_struct(s: *Stmt) {
    println!("typedef struct ", s.name, " {");
    if s.struct_fields != null {
        for let i: int = 0; i < s.struct_fields.len(); i++ {
            let f: Field = s.struct_fields.get(i);
            print!("    ", type_to_c(f.ty), " ", f.name); println!(";");
        }
    }
    println!("} ", s.name, ";");
    println!("");
}

fn emit_enum(s: *Stmt) {
    let mut has_payload: bool = false;
    if s.enum_variants != null {
        for let i: int = 0; i < s.enum_variants.len(); i++ {
            let v: EnumVariant = s.enum_variants.get(i);
            if v.fields != null && v.fields.len() > 0 { has_payload = true; }
        }
    }
    println!("typedef struct ", s.name, " {");
    println!("    int tag;");
    if has_payload {
        println!("    union {");
        if s.enum_variants != null {
            for let i: int = 0; i < s.enum_variants.len(); i++ {
                let v: EnumVariant = s.enum_variants.get(i);
                if v.fields == null || v.fields.len() == 0 { continue; }
                if v.fields.len() == 1 {
                    let t: Type = v.fields.get(0);
                    print!("        ");
                    print!(type_to_c(&t));
                    print!(" v_");
                    print!(v.name);
                    println!(";");
                } else {
                    print!("        struct { ");
                    for let j: int = 0; j < v.fields.len(); j++ {
                        if j > 0 { print!(" "); }
                        let t: Type = v.fields.get(j);
                        print!(type_to_c(&t));
                        print!(" f");
                        print!(j);
                        print!(";");
                    }
                    print!(" } v_");
                    print!(v.name);
                    println!(";");
                }
            }
        }
        println!("    } data;");
    }
    println!("} ", s.name, ";");
    if s.enum_variants != null {
        for let i: int = 0; i < s.enum_variants.len(); i++ {
            let v: EnumVariant = s.enum_variants.get(i);
            print!("#define ");
            print!(s.name);
            print!("_");
            print!(v.name);
            print!(" ");
            print!(i);
            println!("");
        }
    }
    println!("");
}

pub fn emit_program(program: *Vector<Stmt>) {
    println!("#include <stdio.h>");
    println!("#include <stdlib.h>");
    println!("#include <stdbool.h>");
    println!("#include <stdint.h>");
    println!("#include <stddef.h>");
    println!("#include <string.h>");
    println!("");

    emit_stdlib_runtime();

    let g: *CG = CG::new();

    // ---- Concurrency pre-pass: collect chan inner types + emit pthread runtime
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        collect_chan_in_stmt(g, &s);
    }
    emit_chan_runtime(g);

    // ---- Errors-as-values pre-pass: collect Result inner types + emit runtime
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        collect_result_in_stmt(g, &s);
    }
    emit_result_runtime(g);

    // Register generic struct + fn + impl-method templates.
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_STRUCT {
            if s.type_params != null && s.type_params.len() > 0 {
                g.generic_structs.insert(s.name, s);
            } else {
                g.structs.insert(s.name, s);
            }
        }
        if s.kind == ST_FN {
            if s.type_params != null && s.type_params.len() > 0 {
                g.generic_fns.insert(s.name, s);
            } else {
                g.fns.insert(s.name, s);
            }
        }
        if s.kind == ST_ENUM {
            g.enums.insert(s.name, s);
        }
        if s.kind == ST_IMPL && (s.type_params == null || s.type_params.len() == 0)
           && s.impl_target != null && s.impl_methods != null {
            let mut prefix: string = "X";
            if s.impl_target.kind == TY_NAMED { prefix = s.impl_target.name; }
            for let j: int = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                let synth: *Stmt = calloc(1, sizeof(Stmt)) as *Stmt;
                *synth = m;
                synth.name = prefix.concat("_").concat(m.name);
                g.fns.insert(synth.name, *synth);
            }
        }
        if s.kind == ST_IMPL && s.type_params != null && s.type_params.len() > 0
           && s.impl_target != null && s.impl_methods != null {
            // Build mangled prefix from target's name.
            let mut prefix: string = "X";
            if s.impl_target.kind == TY_NAMED { prefix = s.impl_target.name; }
            if s.impl_target.kind == TY_GENERIC { prefix = s.impl_target.name; }
            // Register each method as a generic fn under `Type_method` name.
            for let j: int = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                let mname: string = prefix.concat("_").concat(m.name);
                // Synthesize a generic fn Stmt with the impl's type_params merged
                // into the method's type_params.
                let synth: *Stmt = calloc(1, sizeof(Stmt)) as *Stmt;
                *synth = m;
                synth.name = mname;
                let combined: *Vector<string> = Vector::new();
                for let k: int = 0; k < s.type_params.len(); k++ {
                    combined.push(s.type_params.get(k));
                }
                if m.type_params != null {
                    for let k: int = 0; k < m.type_params.len(); k++ {
                        combined.push(m.type_params.get(k));
                    }
                }
                synth.type_params = combined;
                g.generic_fns.insert(mname, *synth);
            }
        }
    }

    // Pre-pass: backfill `let v = Generic::new()` (no annot) by inferring T
    // from the first subsequent use of v. Must run AFTER generic fn registry
    // is populated and BEFORE the generic-uses collection below.
    infer_let_types_in_program(g, program);

    // Walk the program collecting Type::Generic uses, emit specialized structs.
    let monos: *Vector<Type> = Vector::new();
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        collect_generic_uses_in_stmt(&s, monos);
    }
    // Emit forward typedefs first (mono structs + concrete).
    for let i: int = 0; i < monos.len(); i++ {
        let t: Type = monos.get(i);
        let mangled: string = mangle_generic(t.name, t.args);
        if !g.emitted_monos.contains(mangled) {
            g.emitted_monos.insert(mangled, true);
            println!("typedef struct ", mangled, " ", mangled, ";");
        }
    }
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_STRUCT && (s.type_params == null || s.type_params.len() == 0) {
            println!("typedef struct ", s.name, " ", s.name, ";");
        }
    }
    println!("");

    // Emit specialized struct bodies.
    for let i: int = 0; i < monos.len(); i++ {
        let t: Type = monos.get(i);
        emit_struct_mono(g, &t);
    }

    // Concrete struct definitions.
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_STRUCT && (s.type_params == null || s.type_params.len() == 0) {
            emit_struct(&s);
        }
        if s.kind == ST_ENUM { emit_enum(&s); }
    }

    // Top-level const definitions (#define for ints, static const for others).
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_CONST {
            emit_top_const(g, &s);
        }
    }
    println!("");

    // Forward fn declarations (concrete only).
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && (s.type_params == null || s.type_params.len() == 0) {
            emit_fn_signature(&s); println!(";");
        }
    }

    // Pre-scan: walk every concrete fn / impl method to discover all generic
    // call sites. Emit forward declarations for each mono so their later
    // bodies can be called from anywhere.
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && (s.type_params == null || s.type_params.len() == 0) {
            prescan_stmt(g, &s);
        }
        if s.kind == ST_IMPL && (s.type_params == null || s.type_params.len() == 0) {
            if s.impl_methods != null {
                for let j: int = 0; j < s.impl_methods.len(); j++ {
                    let m: Stmt = s.impl_methods.get(j);
                    prescan_stmt(g, &m);
                }
            }
        }
    }
    // Walk the queued monos transitively (a mono body may call other generics).
    let mut idx: int = 0;
    while idx < g.fn_mono_queue.len() {
        let entry: FnMonoEntry = g.fn_mono_queue.get(idx);
        if g.generic_fns.contains(entry.name) {
            let template: Stmt = g.generic_fns.get(entry.name);
            // Set up scope with substituted param types so receiver-type lookup
            // works inside the substituted body.
            g.scope.clear();
            if template.fn_params != null {
                for let j: int = 0; j < template.fn_params.len(); j++ {
                    let p: Param = template.fn_params.get(j);
                    let pt: *Type = subst_type(p.ty, template.type_params, entry.args);
                    g.declare(p.name, pt);
                }
            }
            if template.fn_body != null {
                for let j: int = 0; j < template.fn_body.len(); j++ {
                    let b: Stmt = template.fn_body.get(j);
                    let nb: *Stmt = subst_stmt(&b, template.type_params, entry.args, g.generic_structs);
                    if nb != null { prescan_stmt(g, nb); }
                }
            }
        }
        idx = idx + 1;
    }
    // Now emit forward declarations for every queued mono.
    for let i: int = 0; i < g.fn_mono_queue.len(); i++ {
        let entry: FnMonoEntry = g.fn_mono_queue.get(i);
        if g.generic_fns.contains(entry.name) {
            let template: Stmt = g.generic_fns.get(entry.name);
            let mangled: string = mangle_generic(entry.name, entry.args);
            emit_mono_forward_decl(g, mangled, &template, entry.args);
        }
    }
    println!("");

    // Pre-pass: walk all fn bodies to discover EX_FNEXPR uses. Lift each
    // into g.anon_fns and rewrite the expression in place to EX_IDENT
    // referring to the synthetic name. Output forward decls so the user
    // fns can reference them.
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        lift_anons_in_stmt(g, &s);
    }
    for let i: int = 0; i < g.anon_fns.len(); i++ {
        let af: AnonFn = g.anon_fns.get(i);
        print!(type_to_c(af.ret_ty), " ", af.name, "(");
        if af.params == null || af.params.len() == 0 {
            print!("void");
        } else {
            for let j: int = 0; j < af.params.len(); j++ {
                if j > 0 { print!(", "); }
                let p: Param = af.params.get(j);
                print!(type_to_c(p.ty), " ", p.name);
            }
        }
        println!(");");
    }
    println!("");

    // Pre-emit spawn stubs (one per spawn site). The counter `g.spawn_count`
    // resets to 0 after this so the emit-pass walks the AST in the same order
    // and pulls the matching ID.
    g.spawn_count = 0;
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        pre_emit_spawn_stubs_in_stmt(g, &s);
    }
    g.spawn_count = 0;

    // Function + impl definitions (skip generic ones, and skip extern/bodyless).
    for let i: int = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && (s.type_params == null || s.type_params.len() == 0)
           && s.fn_body != null {
            emit_fn(g, &s); println!("");
        }
        if s.kind == ST_IMPL && (s.type_params == null || s.type_params.len() == 0) {
            emit_impl(g, &s);
        }
    }

    // Drain generic fn mono queue. New monos may queue more; loop until empty.
    while g.fn_mono_queue.len() > 0 {
        let e: FnMonoEntry = g.fn_mono_queue.pop();
        if !g.generic_fns.contains(e.name) { continue; }
        let template: Stmt = g.generic_fns.get(e.name);
        let mangled: string = mangle_generic(e.name, e.args);
        // Substitute type params throughout the body / params / ret.
        let new_params_v: *Vector<Param> = Vector::new();
        if template.fn_params != null {
            for let i: int = 0; i < template.fn_params.len(); i++ {
                let p: Param = template.fn_params.get(i);
                let np: Param = Param { name: p.name, ty: subst_type(p.ty, template.type_params, e.args) };
                new_params_v.push(np);
            }
        }
        let new_ret: *Type = subst_type(template.fn_ret_ty, template.type_params, e.args);
        let new_body: *Vector<Stmt> = Vector::new();
        if template.fn_body != null {
            for let i: int = 0; i < template.fn_body.len(); i++ {
                let b: Stmt = template.fn_body.get(i);
                let nb: *Stmt = subst_stmt(&b, template.type_params, e.args, g.generic_structs);
                if nb != null { new_body.push(*nb); }
            }
        }
        // Emit the specialized fn.
        print!(type_to_c(new_ret), " ", mangled, "(");
        if new_params_v.len() == 0 {
            print!("void");
        } else {
            for let j: int = 0; j < new_params_v.len(); j++ {
                if j > 0 { print!(", "); }
                let p: Param = new_params_v.get(j);
                print!(type_to_c(p.ty), " ", p.name);
            }
        }
        println!(") {");
        g.scope.clear();
        let saved_d: *Vector<Expr> = g.defer_stack;
        let saved_dr: *Vector<Expr> = g.auto_drop_stack;
        let nd_q: *Vector<Expr> = Vector::new();
        let nadr_q: *Vector<Expr> = Vector::new();
        g.defer_stack = nd_q;
        g.auto_drop_stack = nadr_q;
        for let j: int = 0; j < new_params_v.len(); j++ {
            let p: Param = new_params_v.get(j);
            g.declare(p.name, p.ty);
        }
        for let j: int = 0; j < new_body.len(); j++ {
            let b: Stmt = new_body.get(j);
            emit_stmt(g, &b, 1);
        }
        g.emit_deferred_reverse(1);
        g.defer_stack = saved_d;
        g.auto_drop_stack = saved_dr;
        println!("}");
        println!("");
    }

    // Emit all collected anonymous fn lifts.
    for let i: int = 0; i < g.anon_fns.len(); i++ {
        let af: AnonFn = g.anon_fns.get(i);
        // Signature
        print!(type_to_c(af.ret_ty), " ", af.name, "(");
        if af.params == null || af.params.len() == 0 {
            print!("void");
        } else {
            for let j: int = 0; j < af.params.len(); j++ {
                if j > 0 { print!(", "); }
                let p: Param = af.params.get(j);
                print!(type_to_c(p.ty), " ", p.name);
            }
        }
        println!(") {");
        g.scope.clear();
        let saved_d: *Vector<Expr> = g.defer_stack;
        let saved_dr: *Vector<Expr> = g.auto_drop_stack;
        let nd: *Vector<Expr> = Vector::new();
        let nadr: *Vector<Expr> = Vector::new();
        g.defer_stack = nd;
        g.auto_drop_stack = nadr;
        if af.params != null {
            for let j: int = 0; j < af.params.len(); j++ {
                let p: Param = af.params.get(j);
                g.declare(p.name, p.ty);
            }
        }
        if af.body != null {
            for let j: int = 0; j < af.body.len(); j++ {
                let b: Stmt = af.body.get(j);
                emit_stmt(g, &b, 1);
            }
        }
        g.emit_deferred_reverse(1);
        g.defer_stack = saved_d;
        g.auto_drop_stack = saved_dr;
        println!("}");
        println!("");
    }

    g.free();
}

fn emit_top_const(g: *CG, s: *Stmt) {
    // Use #define for int/bool primitives (compatible with `case` labels and
    // simpler than static const in C). For others, emit static const.
    if s.let_value == null { return; }
    if s.let_ty != null && s.let_ty.kind == TY_NAMED
       && (s.let_ty.name.eq("int") || s.let_ty.name.eq("uint")
           || s.let_ty.name.eq("i32") || s.let_ty.name.eq("i64")) {
        print!("#define ", s.name, " ");
        emit_expr(g, s.let_value);
        println!("");
        return;
    }
    print!("static const ");
    if s.let_ty != null {
        print!(type_to_c(s.let_ty), " ", s.name);
    } else {
        print!("int ", s.name);
    }
    print!(" = ");
    emit_expr(g, s.let_value);
    println!(";");
}

fn emit_struct_mono(g: *CG, t: *Type) {
    if t == null || t.kind != TY_GENERIC { return; }
    if !g.generic_structs.contains(t.name) { return; }
    let template: Stmt = g.generic_structs.get(t.name);
    let mangled: string = mangle_generic(t.name, t.args);
    // Dedup: the same mono can appear many times in the collected uses; the
    // earlier typedef pass already inserted into emitted_monos, but here we
    // need our own marker for "body emitted".
    let body_key: string = mangled.concat("__body");
    if g.emitted_monos.contains(body_key) { return; }
    g.emitted_monos.insert(body_key, true);
    println!("struct ", mangled, " {");
    if template.struct_fields != null && template.type_params != null {
        for let i: int = 0; i < template.struct_fields.len(); i++ {
            let f: Field = template.struct_fields.get(i);
            let sub: *Type = subst_type(f.ty, template.type_params, t.args);
            print!("    ", type_to_c(sub), " ", f.name); println!(";");
        }
    }
    println!("};");
    println!("");
}

fn collect_generic_uses_in_type(t: *Type, out: *Vector<Type>) {
    if t == null { return; }
    if t.kind == TY_GENERIC {
        if t.args != null {
            for let i: int = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                collect_generic_uses_in_type(&a, out);
            }
        }
        out.push(*t);
    }
    if t.kind == TY_POINTER || t.kind == TY_BORROW
       || t.kind == TY_BORROW_MUT || t.kind == TY_SLICE {
        collect_generic_uses_in_type(t.inner, out);
    }
}

fn collect_generic_uses_in_stmt(s: *Stmt, out: *Vector<Type>) {
    if s == null { return; }
    // Skip generic fn signatures and bodies entirely — type vars (T, etc.) are
    // not concrete uses, and the substituted versions will be collected later.
    let is_generic: bool = s.type_params != null && s.type_params.len() > 0;
    if is_generic { return; }

    if s.let_ty != null { collect_generic_uses_in_type(s.let_ty, out); }
    if s.fn_ret_ty != null { collect_generic_uses_in_type(s.fn_ret_ty, out); }
    if s.fn_params != null {
        for let i: int = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            collect_generic_uses_in_type(p.ty, out);
        }
    }
    if s.struct_fields != null {
        for let i: int = 0; i < s.struct_fields.len(); i++ {
            let f: Field = s.struct_fields.get(i);
            collect_generic_uses_in_type(f.ty, out);
        }
    }
    if s.fn_body != null {
        for let i: int = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            collect_generic_uses_in_stmt(&b, out);
        }
    }
    if s.then_body != null {
        for let i: int = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            collect_generic_uses_in_stmt(&b, out);
        }
    }
    if s.else_body != null {
        for let i: int = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            collect_generic_uses_in_stmt(&b, out);
        }
    }
    if s.impl_methods != null {
        for let i: int = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            collect_generic_uses_in_stmt(&m, out);
        }
    }
}
