struct Point {
    x: int,
    y: int,
}

fn print_n(n: int) -> int {
    println!("got =", n);
    return n;
}

fn main() -> int {
    defer println!("first deferred");
    defer println!("second deferred (runs first - LIFO)");

    // Auto-drop: T { ... } in *T → malloc + auto-free.
    let p: *Point = Point { x: 10, y: 32 };
    let sum: int = p.x + p.y;
    println!("sum =", sum);

    return print_n(sum);
}
